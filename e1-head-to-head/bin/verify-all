#!/usr/bin/env bash
# verify-all: compile and verify all head-to-head responses (beagle + raw Clojure).
#
# Usage:
#   bin/verify-all [TASK_PREFIX]
#
# Without arguments: runs all tasks. With prefix (e.g. "04"): runs matching tasks.

set -euo pipefail

beagle_root="$(cd "$(dirname "$0")/../../.." && pwd)"
h2h_dir="$beagle_root/experiments/head-to-head"
target_clj="$beagle_root/runtime/src/beagle/target.clj"
runtime_dir="$beagle_root/runtime"

pass=0
fail=0
total=0

verify_one() {
    local response="$1"
    local task_name="$2"
    local verify_file="$h2h_dir/verify/${task_name}.verify.clj"
    local ext="${response##*.}"
    local label="$(basename "$response")"

    if [[ ! -f "$verify_file" ]]; then
        echo "$label: NO_VERIFY"
        return
    fi

    mkdir -p "$(dirname "$target_clj")"
    total=$((total + 1))
    start_ns=$(date +%s%N)

    if [[ "$ext" == "rkt" ]]; then
        if ! racket "$response" 2>/dev/null | \
           sed -E '1,/^\(ns /s/^\(ns [a-zA-Z0-9._-]+/(ns beagle.target/' > "$target_clj"; then
            end_ns=$(date +%s%N)
            elapsed_ms=$(( (end_ns - start_ns) / 1000000 ))
            echo "$label: COMPILE_FAIL ${elapsed_ms}ms"
            fail=$((fail + 1))
            rm -f "$target_clj"
            return
        fi
    elif [[ "$ext" == "clj" ]]; then
        sed -E '1,/^\(ns /s/^\(ns [a-zA-Z0-9._-]+/(ns beagle.target/' \
            "$response" > "$target_clj"
    else
        echo "$label: UNKNOWN_EXT"
        return
    fi

    verify_code="$(cat "$verify_file")"
    if (cd "$runtime_dir" && \
        clojure -M -e "(require '[beagle.target :as r]) $verify_code") > /dev/null 2>&1; then
        end_ns=$(date +%s%N)
        elapsed_ms=$(( (end_ns - start_ns) / 1000000 ))
        echo "$label: PASS ${elapsed_ms}ms"
        pass=$((pass + 1))
    else
        end_ns=$(date +%s%N)
        elapsed_ms=$(( (end_ns - start_ns) / 1000000 ))
        echo "$label: BEHAVIOR_FAIL ${elapsed_ms}ms"
        fail=$((fail + 1))
    fi

    rm -f "$target_clj"
}

for verify_file in "$h2h_dir"/verify/*.verify.clj; do
    task_name="$(basename "$verify_file" .verify.clj)"
    if [[ $# -ge 1 ]] && [[ "$task_name" != ${1}* ]]; then
        continue
    fi
    for response in "$h2h_dir"/responses/${task_name}-*.rkt "$h2h_dir"/responses/${task_name}-*.clj; do
        [[ -f "$response" ]] || continue
        verify_one "$response" "$task_name"
    done
done

echo ""
echo "=== HEAD-TO-HEAD: $pass/$total passed, $fail failed ==="
