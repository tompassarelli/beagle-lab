#!/usr/bin/env bash
# Run the master verification script against a set of .clj modules.
#
# Usage: bin/verify-one <src-dir> [verify-script]
#
# src-dir: directory containing catalog.clj, customers.clj, inventory.clj, orders.clj, reports.clj
# verify-script: defaults to verify/master.verify.clj
#
# The src-dir is added to the classpath so Clojure can resolve (require '[catalog :as cat]) etc.
# Exit code: 0 if all assertions pass, 1 otherwise.

set -euo pipefail

if [[ $# -lt 1 ]]; then
    echo "usage: bin/verify-one <src-dir> [verify-script]" >&2
    exit 2
fi

src_dir="$(cd "$1" && pwd)"
exp_root="$(cd "$(dirname "$0")/.." && pwd)"
verify_script="${2:-${exp_root}/verify/master.verify.clj}"

if [[ ! -f "$verify_script" ]]; then
    echo "ERROR: verify script not found: $verify_script" >&2
    exit 2
fi

# check required modules exist
for mod in catalog customers inventory orders reports; do
    if [[ ! -f "${src_dir}/${mod}.clj" ]]; then
        echo "MISSING: ${src_dir}/${mod}.clj" >&2
        exit 2
    fi
done

# run with src_dir on classpath
exec clojure -Sdeps "{:paths [\"${src_dir}\" \"$(dirname "$verify_script")\"]}" \
    -M -m master.verify
