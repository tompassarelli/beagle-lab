#!/usr/bin/env python3
"""Parse a Claude Code agent JSONL transcript into a structured timeline.

Usage:
  bin/experiment-timeline <transcript.output>
  bin/experiment-timeline <transcript.output> --summary
  bin/experiment-timeline <transcript.output> --json

Output: one line per tool call with timestamp, duration, tool, target, and outcome.
"""

import json
import sys
import os
from datetime import datetime

def parse_timestamp(ts):
    if not ts:
        return None
    ts = ts.rstrip("Z")
    if "." in ts:
        return datetime.fromisoformat(ts)
    return datetime.fromisoformat(ts)

def extract_target(tool, inp):
    """Extract the meaningful target from a tool call's input."""
    if tool == "Bash":
        cmd = inp.get("command", "")
        return cmd[:120]
    elif tool == "Read":
        path = inp.get("file_path", "")
        return os.path.basename(path)
    elif tool == "Edit":
        path = inp.get("file_path", "")
        old = inp.get("old_string", "")[:40]
        return f"{os.path.basename(path)} ({len(old)}ch)"
    elif tool == "Write":
        path = inp.get("file_path", "")
        return os.path.basename(path)
    return ""

def classify_bash(cmd):
    """Classify a bash command into a category."""
    if "beagle-check" in cmd:
        return "beagle-check"
    elif "beagle-sig" in cmd:
        return "beagle-sig"
    elif "beagle-fields" in cmd:
        return "beagle-fields"
    elif "beagle-callers" in cmd:
        return "beagle-callers"
    elif "beagle-provides" in cmd:
        return "beagle-provides"
    elif "beagle-impact" in cmd:
        return "beagle-impact"
    elif "clj-sig" in cmd:
        return "clj-sig"
    elif "clj-fields" in cmd:
        return "clj-fields"
    elif "clj-callers" in cmd:
        return "clj-callers"
    elif "clj-provides" in cmd:
        return "clj-provides"
    elif "beagle-build" in cmd:
        return "beagle-build"
    elif "verify" in cmd:
        return "verify"
    elif cmd.startswith("ls ") or cmd.startswith("find "):
        return "ls/find"
    elif cmd.startswith("grep ") or cmd.startswith("cat "):
        return "grep/cat"
    else:
        return "bash"

def extract_outcome(tool, inp, result_content):
    """Extract a short outcome string from a tool result."""
    if not result_content:
        return ""
    text = str(result_content)[:500]

    if tool == "Bash":
        cmd = inp.get("command", "")
        if "beagle-check" in cmd:
            if "error" in text.lower() or "expected" in text.lower():
                first_line = text.split("\n")[0][:80]
                return f"ERROR: {first_line}"
            return "clean"
        return text.split("\n")[0][:80] if text.strip() else "(empty)"

    if tool == "Edit":
        if "updated successfully" in text:
            return "ok"
        return text[:60]

    if tool == "Read":
        lines = text.count("\n")
        return f"{lines} lines"

    return text[:60]

def parse_transcript(path):
    """Parse JSONL transcript into a list of events."""
    events = []
    pending_calls = {}  # tool_use_id -> {tool, input, timestamp, ...}

    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                d = json.loads(line)
            except json.JSONDecodeError:
                continue

            ts = parse_timestamp(d.get("timestamp"))
            msg = d.get("message", {})
            content = msg.get("content", [])

            if isinstance(content, str):
                continue

            if not isinstance(content, list):
                continue

            for c in content:
                if not isinstance(c, dict):
                    continue

                if c.get("type") == "tool_use":
                    tool_id = c.get("id")
                    tool = c.get("name", "")
                    inp = c.get("input", {})
                    pending_calls[tool_id] = {
                        "tool": tool,
                        "input": inp,
                        "start": ts,
                        "target": extract_target(tool, inp),
                    }
                    if tool == "Bash":
                        pending_calls[tool_id]["category"] = classify_bash(inp.get("command", ""))
                    else:
                        pending_calls[tool_id]["category"] = tool.lower()

                elif c.get("type") == "tool_result":
                    tool_id = c.get("tool_use_id")
                    if tool_id in pending_calls:
                        call = pending_calls.pop(tool_id)
                        duration = None
                        if call["start"] and ts:
                            duration = (ts - call["start"]).total_seconds()
                        events.append({
                            "start": call["start"],
                            "end": ts,
                            "duration": duration,
                            "tool": call["tool"],
                            "category": call["category"],
                            "target": call["target"],
                            "outcome": extract_outcome(call["tool"], call["input"], c.get("content")),
                        })

    return events

def print_timeline(events):
    if not events:
        print("(no tool calls found)")
        return

    t0 = events[0]["start"]
    prev_end = t0

    for e in events:
        offset = (e["start"] - t0).total_seconds() if e["start"] and t0 else 0
        duration = e["duration"] if e["duration"] else 0
        think_time = (e["start"] - prev_end).total_seconds() if e["start"] and prev_end else 0

        cat = e["category"]
        target = e["target"]
        outcome = e["outcome"]

        # Truncate for display
        if len(target) > 80:
            target = target[:77] + "..."
        if len(outcome) > 60:
            outcome = outcome[:57] + "..."

        think_str = f"  (+{think_time:.0f}s think)" if think_time > 2 else ""
        print(f"{offset:6.0f}s  {cat:<16s} {duration:5.1f}s  {target:<80s}  {outcome}{think_str}")

        if e["end"]:
            prev_end = e["end"]

def print_summary(events):
    if not events:
        print("(no tool calls found)")
        return

    t0 = events[0]["start"]
    t_end = events[-1]["end"] or events[-1]["start"]
    total_wall = (t_end - t0).total_seconds()

    # Aggregate by category
    cats = {}
    for e in events:
        cat = e["category"]
        if cat not in cats:
            cats[cat] = {"count": 0, "total_dur": 0, "errors": 0}
        cats[cat]["count"] += 1
        cats[cat]["total_dur"] += e["duration"] or 0
        if "ERROR" in (e.get("outcome") or ""):
            cats[cat]["errors"] += 1

    # Think time
    total_tool_time = sum(e["duration"] or 0 for e in events)
    total_think_time = total_wall - total_tool_time

    # Files read/edited
    files_read = set()
    files_edited = set()
    for e in events:
        if e["tool"] == "Read":
            files_read.add(e["target"])
        elif e["tool"] == "Edit":
            fname = e["target"].split(" ")[0]
            files_edited.add(fname)

    print(f"Wall clock:    {total_wall:.0f}s")
    print(f"Tool time:     {total_tool_time:.0f}s ({total_tool_time/total_wall*100:.0f}%)")
    print(f"Think time:    {total_think_time:.0f}s ({total_think_time/total_wall*100:.0f}%)")
    print(f"Tool calls:    {len(events)}")
    print(f"Files read:    {len(files_read)}")
    print(f"Files edited:  {len(files_edited)}")
    print()
    print(f"{'Category':<18s} {'Count':>5s} {'Total':>6s} {'Avg':>6s} {'Errors':>6s}")
    print("-" * 48)
    for cat in sorted(cats.keys(), key=lambda c: -cats[c]["total_dur"]):
        c = cats[cat]
        avg = c["total_dur"] / c["count"] if c["count"] else 0
        err = f"{c['errors']}" if c['errors'] else ""
        print(f"{cat:<18s} {c['count']:>5d} {c['total_dur']:>5.1f}s {avg:>5.1f}s {err:>6s}")

def print_json(events):
    out = []
    t0 = events[0]["start"] if events else None
    for e in events:
        out.append({
            "offset_s": (e["start"] - t0).total_seconds() if e["start"] and t0 else 0,
            "duration_s": e["duration"],
            "tool": e["tool"],
            "category": e["category"],
            "target": e["target"],
            "outcome": e["outcome"],
        })
    print(json.dumps(out, indent=2))

def main():
    if len(sys.argv) < 2:
        print("usage: experiment-timeline <transcript.output> [--summary|--json]", file=sys.stderr)
        sys.exit(2)

    path = sys.argv[1]
    mode = sys.argv[2] if len(sys.argv) > 2 else "--timeline"

    events = parse_transcript(path)

    if mode == "--summary":
        print_summary(events)
    elif mode == "--json":
        print_json(events)
    else:
        print_timeline(events)

if __name__ == "__main__":
    main()
