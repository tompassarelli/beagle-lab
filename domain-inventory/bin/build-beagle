#!/usr/bin/env bash
# Compile beagle .rkt files to .clj for the v2 inventory experiment.
#
# Usage: bin/build-beagle <input-dir> [output-dir]
#
# Input dir should contain: catalog.rkt, customers.rkt, inventory.rkt, orders.rkt, reports.rkt
# Output dir defaults to <input-dir>/compiled/

set -euo pipefail

if [[ $# -lt 1 ]]; then
    echo "usage: bin/build-beagle <input-dir> [output-dir]" >&2
    exit 2
fi

input_dir="$1"
output_dir="${2:-${input_dir}/compiled}"
beagle_root="$(cd "$(dirname "$0")/../../.." && pwd)"

mkdir -p "$output_dir"

modules=(catalog customers inventory orders reports)
failed=0
compiled=0

for mod in "${modules[@]}"; do
    src="${input_dir}/${mod}.rkt"
    if [[ ! -f "$src" ]]; then
        echo "SKIP: $src not found" >&2
        continue
    fi

    out="${output_dir}/${mod}.clj"
    if "$beagle_root/bin/beagle-build" "$src" "$out" 2>/dev/null; then
        # strip source metadata for cleaner output
        sed -i 's/\^{:line [0-9]* :file "[^"]*"} //g' "$out"
        compiled=$((compiled + 1))
    else
        echo "COMPILE_FAIL: $src" >&2
        failed=$((failed + 1))
    fi
done

echo "compiled: $compiled, failed: $failed, output: $output_dir"
[[ $failed -eq 0 ]]
