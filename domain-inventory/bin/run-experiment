#!/usr/bin/env bash
# Run a single experiment trial: build (if beagle) + verify.
#
# Usage: bin/run-experiment <track> <response-dir>
#   track: "beagle" or "clojure"
#   response-dir: directory containing the agent's output files
#
# Output: PASS/FAIL with timing and assertion counts to stdout.

set -euo pipefail

if [[ $# -ne 2 ]]; then
    echo "usage: bin/run-experiment <beagle|clojure> <response-dir>" >&2
    exit 2
fi

track="$1"
response_dir="$2"
exp_root="$(cd "$(dirname "$0")/.." && pwd)"
start_ns=$(date +%s%N)

if [[ "$track" == "beagle" ]]; then
    # Step 1: compile beagle to clojure
    compiled_dir="${response_dir}/compiled"
    if ! "$exp_root/bin/build-beagle" "$response_dir" "$compiled_dir" >/dev/null 2>&1; then
        end_ns=$(date +%s%N)
        elapsed_ms=$(( (end_ns - start_ns) / 1000000 ))
        echo "COMPILE_FAIL ${elapsed_ms}ms $response_dir"
        exit 1
    fi
    src_dir="$compiled_dir"
elif [[ "$track" == "clojure" ]]; then
    src_dir="$response_dir"
else
    echo "ERROR: track must be 'beagle' or 'clojure'" >&2
    exit 2
fi

# Step 2: verify
output=$("$exp_root/bin/verify-one" "$src_dir" 2>&1) || true
end_ns=$(date +%s%N)
elapsed_ms=$(( (end_ns - start_ns) / 1000000 ))

# Parse results from last line (format: "N passed, M failed")
last_line=$(echo "$output" | tail -1)
if echo "$last_line" | grep -q "0 failed"; then
    echo "PASS ${elapsed_ms}ms $response_dir"
    echo "$last_line"
    exit 0
else
    echo "BEHAVIOR_FAIL ${elapsed_ms}ms $response_dir"
    echo "$output" | grep "^FAIL:" | head -10
    echo "$last_line"
    exit 1
fi
