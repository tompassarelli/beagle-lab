#lang beagle

(ns e19.c-agent)

;; ============================================================================
;; Route specification — define routes ONCE as data
;; ============================================================================

(def routes : (Vec (Vec String))
  [["/users" "handle-users"]
   ["/products" "handle-products"]])

;; ============================================================================
;; Generic dispatch — driven by route data, no per-route repetition
;; ============================================================================

(defn find-handler [(path : String) (rt : (Vec (Vec String)))] : String?
  (let [matches (filter (fn [(r : (Vec String))] (= (first r) path)) rt)]
    (if (empty? matches)
      nil
      (second (first matches)))))

(defn dispatch [(path : String)] : String
  (let [handler (find-handler path routes)]
    (if (nil? handler)
      "404 Not Found"
      handler)))

;; ============================================================================
;; Log wrapper — also driven by dispatch, no route repetition
;; ============================================================================

(defn log-request [(path : String)] : String
  (do
    (println (str "[LOG] GET " path))
    (dispatch path)))

;; ============================================================================
;; Handler stubs
;; ============================================================================

(defn handle-users [] : String "handle-users")
(defn handle-products [] : String "handle-products")

;; ============================================================================
;; Test calls — expected output
;; ============================================================================

(println (str "GET /users -> " (dispatch "/users")))
(println (str "GET /products -> " (dispatch "/products")))
(println (str "GET /unknown -> " (dispatch "/unknown")))
(println (log-request "/users"))
