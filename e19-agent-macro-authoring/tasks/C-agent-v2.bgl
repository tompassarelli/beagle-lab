#lang beagle

(ns e19.c-agent-v2)

;; ============================================================================
;; Route specification — define routes ONCE as data (method + path + handler)
;; ============================================================================

(def routes : (Vec (Vec String))
  [["GET" "/users" "handle-users"]
   ["POST" "/users" "create-user"]
   ["GET" "/products" "handle-products"]])

;; ============================================================================
;; Generic dispatch — driven by route data, matches method + path
;; ============================================================================

(defn find-handler [(method : String) (path : String) (rt : (Vec (Vec String)))] : String?
  (let [matches (filter (fn [(r : (Vec String))] (and (= (first r) method) (= (second r) path))) rt)]
    (if (empty? matches)
      nil
      (nth (first matches) 2))))

(defn dispatch [(method : String) (path : String)] : String
  (let [handler (find-handler method path routes)]
    (if (nil? handler)
      "404 Not Found"
      handler)))

;; ============================================================================
;; Log wrapper — also driven by dispatch, no route repetition
;; ============================================================================

(defn log-request [(method : String) (path : String)] : String
  (do
    (println (str "[LOG] " method " " path))
    (dispatch method path)))

;; ============================================================================
;; Handler stubs
;; ============================================================================

(defn handle-users [] : String "handle-users")
(defn create-user [] : String "create-user result")
(defn handle-products [] : String "handle-products")

;; ============================================================================
;; Test calls — expected output
;; ============================================================================

(println (str "GET /users -> " (dispatch "GET" "/users")))
(println (str "POST /users -> " (dispatch "POST" "/users")))
(println (str "DELETE /users -> " (dispatch "DELETE" "/users")))
(println (log-request "POST" "/users"))
