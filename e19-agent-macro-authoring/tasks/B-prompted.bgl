#lang beagle

;; E19 Condition B: proc macro router (agent with docs)

(define-macro beagle defrouter
  [(name : Symbol) (routes : (Vec Syntax))] : (Vec Form)
  (let [dispatch-name (format-symbol "~a-dispatch" name)
        log-name (format-symbol "~a-log" name)
        cond-branches (append
          (map (fn [(r : Syntax)]
            (let [path (first r)
                  handler (first (rest r))]
              (list (list '= 'path path) (symbol->string handler))))
            routes)
          (list (list 'true "404 Not Found")))]
    (list
      (make-defn dispatch-name
        (list (make-param 'path 'String))
        'String
        (cons 'cond cond-branches))
      (make-defn log-name
        (list (make-param 'path 'String))
        'String
        (list 'do
          (list 'println (list 'str "[LOG] GET " 'path))
          (list dispatch-name 'path))))))

(defrouter app
  (("/users" handle-users)
   ("/products" handle-products)))

(defn handle-users [] : String "handle-users result")
(defn handle-products [] : String "handle-products result")

(println (str "GET /users -> " (app-dispatch "/users")))
(println (str "GET /products -> " (app-dispatch "/products")))
(println (str "GET /unknown -> " (app-dispatch "/unknown")))
(println (app-log "/users"))
