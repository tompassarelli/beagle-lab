#lang beagle

;; E19 Condition A v2: hand-written router with method matching

(defn handle-users [] : String "handle-users result")
(defn create-user [] : String "create-user result")
(defn handle-products [] : String "handle-products result")

(defn dispatch [(method : String) (path : String)] : String
  (cond
    [(and (= method "GET") (= path "/users")) "handle-users"]
    [(and (= method "POST") (= path "/users")) "create-user"]
    [(and (= method "GET") (= path "/products")) "handle-products"]
    [true "404 Not Found"]))

(defn log-request [(method : String) (path : String)] : String
  (do
    (println (str "[LOG] " method " " path))
    (dispatch method path)))

(println (str "GET /users -> " (dispatch "GET" "/users")))
(println (str "POST /users -> " (dispatch "POST" "/users")))
(println (str "DELETE /users -> " (dispatch "DELETE" "/users")))
(println (log-request "POST" "/users"))
