#lang beagle

;; E19 Condition A: hand-written router (baseline)

(defn handle-users [] : String "handle-users result")
(defn handle-products [] : String "handle-products result")

(defn dispatch [(path : String)] : String
  (cond
    [(= path "/users") "handle-users"]
    [(= path "/products") "handle-products"]
    [true "404 Not Found"]))

(defn log-request [(path : String)] : String
  (do
    (println (str "[LOG] GET " path))
    (dispatch path)))

(println (str "GET /users -> " (dispatch "/users")))
(println (str "GET /products -> " (dispatch "/products")))
(println (str "GET /unknown -> " (dispatch "/unknown")))
(println (log-request "/users"))
