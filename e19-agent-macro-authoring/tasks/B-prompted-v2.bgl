#lang beagle

;; E19 Condition B v2: proc macro router with method matching

(define-macro beagle defrouter
  [(name : Symbol) (routes : (Vec Syntax))] : (Vec Form)
  (let [dispatch-name (format-symbol "~a-dispatch" name)
        log-name (format-symbol "~a-log" name)
        cond-branches (append
          (map (fn [(r : Syntax)]
            (let [m (first r)
                  p (first (rest r))
                  handler (first (rest (rest r)))]
              (list (list 'and (list '= 'method m) (list '= 'path p))
                    (symbol->string handler))))
            routes)
          (list (list 'true "404 Not Found")))]
    (list
      (make-defn dispatch-name
        (list (make-param 'method 'String) (make-param 'path 'String))
        'String
        (cons 'cond cond-branches))
      (make-defn log-name
        (list (make-param 'method 'String) (make-param 'path 'String))
        'String
        (list 'do
          (list 'println (list 'str "[LOG] " 'method " " 'path))
          (list dispatch-name 'method 'path))))))

(defrouter app
  (("GET" "/users" handle-users)
   ("POST" "/users" create-user)
   ("GET" "/products" handle-products)))

(defn handle-users [] : String "handle-users result")
(defn create-user [] : String "create-user result")
(defn handle-products [] : String "handle-products result")

(println (str "GET /users -> " (app-dispatch "GET" "/users")))
(println (str "POST /users -> " (app-dispatch "POST" "/users")))
(println (str "DELETE /users -> " (app-dispatch "DELETE" "/users")))
(println (app-log "POST" "/users"))
