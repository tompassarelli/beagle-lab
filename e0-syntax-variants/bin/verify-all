#!/usr/bin/env bash
# verify-all: run verify-behavior on every response that has a matching
# task verify script. Writes experiments/behavior-scoreboard.md.

set -euo pipefail

beagle_root="$(cd "$(dirname "$0")/../.." && pwd)"
resp_dir="$beagle_root/experiments/responses"
tasks_dir="$beagle_root/experiments/tasks"
out="$beagle_root/experiments/behavior-scoreboard.md"

declare -A variant_total
declare -A variant_pass

{
    echo "# beagle behavior bench — scoreboard"
    echo ""
    echo "Generated $(date '+%Y-%m-%d %H:%M:%S')."
    echo ""
    echo "Each response is compiled to Clojure, run against the task's"
    echo "behavior verification script (\`tasks/<task>.verify.clj\`), and"
    echo "timed end-to-end."
    echo ""
    echo "| response | variant | result | total ms |"
    echo "|---|---|---|---|"

    shopt -s nullglob
    for resp in "$resp_dir"/*.rkt; do
        name="$(basename "$resp" .rkt)"
        # Extract task name (everything before the variant suffix).
        task=""
        variant="unknown"
        for vdir in "$beagle_root/experiments/variants/"*/; do
            vname="$(basename "$vdir")"
            if [[ "$name" == *"-$vname"* ]]; then
                variant="$vname"
                # task is the part before "-$vname"
                task="${name%%-${vname}*}"
                break
            fi
        done

        if [[ -z "$task" ]]; then
            continue
        fi

        verify_file="$tasks_dir/${task}.verify.clj"
        if [[ ! -f "$verify_file" ]]; then
            continue
        fi

        # Run via verify-behavior; capture output
        if output="$("$beagle_root/experiments/bin/verify-behavior" "$resp" "$task" 2>&1)"; then
            # PASS line
            result="✓ PASS"
            ms="$(echo "$output" | grep -oE '[0-9]+ms' | head -1 | tr -d 'ms')"
            variant_total[$variant]=$((${variant_total[$variant]:-0} + 1))
            variant_pass[$variant]=$((${variant_pass[$variant]:-0} + 1))
        else
            if echo "$output" | grep -q BEHAVIOR_FAIL; then
                result="✗ BEHAVIOR_FAIL"
            elif echo "$output" | grep -q COMPILE_FAIL; then
                result="✗ COMPILE_FAIL"
            else
                result="✗ FAIL"
            fi
            ms="$(echo "$output" | grep -oE '[0-9]+ms' | head -1 | tr -d 'ms')"
            variant_total[$variant]=$((${variant_total[$variant]:-0} + 1))
        fi

        echo "| $name | $variant | $result | $ms |"
    done

    echo ""
    echo "## Per-variant behavior pass rates"
    echo ""
    echo "| variant | pass | total | rate |"
    echo "|---|---|---|---|"
    for variant in "${!variant_total[@]}"; do
        pass=${variant_pass[$variant]:-0}
        total=${variant_total[$variant]}
        rate=$(awk "BEGIN { printf \"%.1f%%\", $pass / $total * 100 }")
        echo "| $variant | $pass | $total | $rate |"
    done
} > "$out"

echo "wrote $out"
echo ""
cat "$out"
