#!/usr/bin/env bash
# verify-behavior: compile a beagle response, run it against the task's
# verify.clj, report PASS/FAIL with wall-clock timing.
#
# Usage:
#   bin/verify-behavior <response.rkt> <task-name>
#
# Example:
#   bin/verify-behavior responses/01-greet-a-current.rkt 01-greet
#
# Output:
#   <task>: PASS <ms>ms <kind>   (compile-time + run-time, ok)
#   <task>: COMPILE_FAIL <ms>ms  (beagle compile failed)
#   <task>: BEHAVIOR_FAIL <ms>ms (compiled but verify assertions failed)

set -euo pipefail

if [[ $# -ne 2 ]]; then
    echo "usage: verify-behavior <response.rkt> <task-name>" >&2
    exit 2
fi

response="$1"
task="$2"

beagle_root="$(cd "$(dirname "$0")/../.." && pwd)"
verify_file="$beagle_root/experiments/tasks/${task}.verify.clj"

if [[ ! -f "$verify_file" ]]; then
    echo "$task: NO_VERIFY_SCRIPT" >&2
    exit 2
fi

# 1. Compile beagle source to Clojure, hijacking the ns to beagle.target so
#    the verify script can require it under a fixed alias.
target_clj="$beagle_root/runtime/src/beagle/target.clj"
mkdir -p "$(dirname "$target_clj")"

start_ns=$(date +%s%N)
if ! racket "$response" 2>/dev/null | \
   sed -E '1,/^\(ns /s/^\(ns [a-zA-Z0-9._-]+/(ns beagle.target/' > "$target_clj"; then
    end_ns=$(date +%s%N)
    elapsed_ms=$(( (end_ns - start_ns) / 1000000 ))
    echo "$(basename "$response" .rkt): COMPILE_FAIL ${elapsed_ms}ms"
    rm -f "$target_clj"
    exit 1
fi

# 2. Run the verify script against the loaded namespace.
verify_code="$(cat "$verify_file")"
runtime_dir="$beagle_root/runtime"

if (cd "$runtime_dir" && \
    clojure -M -e "(require '[beagle.target :as r]) $verify_code") > /dev/null 2>&1; then
    end_ns=$(date +%s%N)
    elapsed_ms=$(( (end_ns - start_ns) / 1000000 ))
    echo "$(basename "$response" .rkt): PASS ${elapsed_ms}ms"
    rm -f "$target_clj"
    exit 0
else
    end_ns=$(date +%s%N)
    elapsed_ms=$(( (end_ns - start_ns) / 1000000 ))
    echo "$(basename "$response" .rkt): BEHAVIOR_FAIL ${elapsed_ms}ms"
    rm -f "$target_clj"
    exit 1
fi
