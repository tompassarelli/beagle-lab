#!/usr/bin/env bash
set -euo pipefail

# Score a trial using behavioral tests (E5e).
# Usage: bin/score-behavioral <track> <trial-dir>
# Example: bin/score-behavioral beagle trials/e5d-beagle-run1/
#
# For beagle track: builds .rkt → .clj first, then runs behavioral tests.
# For clojure track: runs behavioral tests directly against .clj files.
#
# Output: per-bug PASS/FAIL and summary score.

TRACK="${1:?Usage: bin/score-behavioral <track> <trial-dir>}"
TRIAL_DIR="${2:?Usage: bin/score-behavioral <track> <trial-dir>}"

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BEAGLE_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Create temp directory for classpath setup
WORK_DIR=$(mktemp -d)
mkdir -p "$WORK_DIR/pipeline"
trap "rm -rf $WORK_DIR" EXIT

if [ "$TRACK" = "beagle" ]; then
  echo "Building beagle .rkt → .clj..."
  if ! "$BEAGLE_ROOT/bin/beagle-build-all" "$TRIAL_DIR/" --out "$WORK_DIR/pipeline" 2>/dev/null; then
    echo "BUILD FAILED — beagle files have compile errors"
    echo ""
    echo "=== E5e BEHAVIORAL TEST RESULTS ==="
    echo "Score: 0% (build failure)"
    exit 1
  fi
  ADAPTER="$SCRIPT_DIR/verify/adapter-beagle.clj"
elif [ "$TRACK" = "clojure" ]; then
  cp "$TRIAL_DIR/"*.clj "$WORK_DIR/pipeline/"
  ADAPTER="$SCRIPT_DIR/verify/adapter-clojure.clj"
else
  echo "Unknown track: $TRACK (use 'beagle' or 'clojure')"
  exit 1
fi

echo "Running behavioral tests (adapter: $(basename $ADAPTER))..."
echo ""

# Run behavioral verify with adapter path passed as system property.
# The test loads the adapter after modules are bootstrapped.
# Suppress intern warnings (cosmetic noise from :refer :all)
OUTPUT=$(clj -Sdeps "{:paths [\"$WORK_DIR\" \"$SCRIPT_DIR/verify\"]}" \
  -J-De5.adapter="$ADAPTER" \
  -M "$SCRIPT_DIR/verify/behavioral.verify.clj" 2>&1 | grep -v "^WARNING") || true

echo "$OUTPUT"

# Extract machine-readable results
PASS_COUNT=$(echo "$OUTPUT" | grep -c "^BUG-.*|PASS|" || true)
FAIL_COUNT=$(echo "$OUTPUT" | grep -c "^BUG-.*|FAIL|" || true)
TOTAL=$((PASS_COUNT + FAIL_COUNT))

if [ $TOTAL -eq 0 ]; then
  echo ""
  echo "ERROR: No test results (possible load failure)"
  echo "Score: 0%"
  exit 1
fi

echo ""
echo "=== BEHAVIORAL SCORE ==="
echo "Track: $TRACK"
echo "Trial: $TRIAL_DIR"
echo "Passed: $PASS_COUNT / $TOTAL"
SCORE=$((PASS_COUNT * 100 / TOTAL))
echo "Score: ${SCORE}%"
