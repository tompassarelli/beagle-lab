#!/usr/bin/env bash
set -euo pipefail

# Run all 6 E5g trials sequentially (3 beagle, 3 clojure)
# Usage: bin/run-e5g-all
#
# Each trial takes ~5-15 min with Opus. Total: ~1-1.5h.

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$SCRIPT_DIR"

echo "=== E5g: Running all 6 trials ==="
echo "3x beagle (verify-after + defunion) + 3x clojure"
echo ""

for RUN in 1 2 3; do
  echo ">>> Beagle run $RUN"
  bin/run-e5g-trial beagle "$RUN"
  echo ""
done

for RUN in 1 2 3; do
  echo ">>> Clojure run $RUN"
  bin/run-e5g-trial clojure "$RUN"
  echo ""
done

echo "=== All E5g trials complete ==="
echo ""
echo "Results:"
for TRIAL in trials/e5g-*; do
  if [ -f "$TRIAL/behavioral-score.json" ]; then
    SCORE=$(grep -o '"pct":[0-9.]*' "$TRIAL/behavioral-score.json" | head -1 | cut -d: -f2)
    echo "  $TRIAL → ${SCORE}%"
  fi
done
