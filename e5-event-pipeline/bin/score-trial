#!/usr/bin/env bash
set -euo pipefail

# Score a bug-detection trial against golden reference.
# Usage: bin/score-trial <track> <trial-dir>
# Example: bin/score-trial beagle responses/e5c-beagle-run1/
#
# Output: per-file diff stats and total score.

TRACK="${1:?Usage: bin/score-trial <track> <trial-dir>}"
TRIAL_DIR="${2:?Usage: bin/score-trial <track> <trial-dir>}"

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
GOLDEN_DIR="$SCRIPT_DIR/golden/$TRACK"
BUGGY_DIR="$SCRIPT_DIR/buggy-original/$TRACK"

if [ "$TRACK" = "beagle" ]; then
  EXT="rkt"
else
  EXT="clj"
fi

MODULES="events projections commands handlers queries pipeline notifications analytics"

total_bug_lines=0
remaining_bug_lines=0
files_perfect=0
files_total=0

echo "=== E5c Trial Scoring ==="
echo "Track: $TRACK"
echo "Trial: $TRIAL_DIR"
echo ""
printf "%-20s %8s %8s %8s %6s\n" "Module" "BugDiff" "Remain" "Fixed" "Score"
printf "%-20s %8s %8s %8s %6s\n" "------" "-------" "------" "-----" "-----"

for mod in $MODULES; do
  file="$mod.$EXT"
  golden="$GOLDEN_DIR/$file"
  buggy="$BUGGY_DIR/$file"
  fixed="$TRIAL_DIR/$file"

  if [ ! -f "$fixed" ]; then
    echo "MISSING: $fixed"
    continue
  fi

  # Lines of diff between buggy-original and golden = total bug surface
  bug_diff=$(diff "$golden" "$buggy" | grep -c '^[<>]' || true)
  # Lines of diff between fixed and golden = remaining unfixed surface
  remain_diff=$(diff "$golden" "$fixed" | grep -c '^[<>]' || true)
  # Fixed = bug_diff - remain_diff (clamped to 0)
  fixed_lines=$((bug_diff - remain_diff))
  if [ $fixed_lines -lt 0 ]; then fixed_lines=0; fi

  if [ $bug_diff -gt 0 ]; then
    score=$((fixed_lines * 100 / bug_diff))
  else
    score=100
  fi

  if [ $remain_diff -eq 0 ]; then
    files_perfect=$((files_perfect + 1))
  fi

  printf "%-20s %8d %8d %8d %5d%%\n" "$mod" "$bug_diff" "$remain_diff" "$fixed_lines" "$score"

  total_bug_lines=$((total_bug_lines + bug_diff))
  remaining_bug_lines=$((remaining_bug_lines + remain_diff))
  files_total=$((files_total + 1))
done

echo ""
total_fixed=$((total_bug_lines - remaining_bug_lines))
if [ $total_fixed -lt 0 ]; then total_fixed=0; fi
if [ $total_bug_lines -gt 0 ]; then
  total_score=$((total_fixed * 100 / total_bug_lines))
else
  total_score=100
fi

echo "Total bug surface: $total_bug_lines lines"
echo "Remaining diff:    $remaining_bug_lines lines"
echo "Fixed:             $total_fixed lines"
echo "Perfect files:     $files_perfect / $files_total"
echo "Overall score:     ${total_score}%"

# Also check if beagle-check-all passes (beagle track only)
if [ "$TRACK" = "beagle" ]; then
  echo ""
  echo "--- Type checker ---"
  CHECKER_OUTPUT=$("$SCRIPT_DIR/../../bin/beagle-check-all" "$TRIAL_DIR" 2>&1) || true
  ERRORS=$(echo "$CHECKER_OUTPUT" | grep "error(s)" | tail -1)
  echo "$ERRORS"
fi
