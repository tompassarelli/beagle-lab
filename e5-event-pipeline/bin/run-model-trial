#!/usr/bin/env bash
set -euo pipefail

# Run a complete model trial: setup → agent → score
# Usage: bin/run-model-trial <model> <track> <run-number>
# Example: bin/run-model-trial sonnet beagle 1
#          bin/run-model-trial haiku clojure 2
#
# Models: sonnet (claude-sonnet-4-6), haiku (claude-haiku-4-5-20251001)
# Tracks: beagle, clojure
#
# Budget: $5 for sonnet, $2 for haiku (per trial)

MODEL_SHORT="${1:?Usage: bin/run-model-trial <model> <track> <run>}"
TRACK="${2:?Usage: bin/run-model-trial <model> <track> <run>}"
RUN="${3:?Usage: bin/run-model-trial <model> <track> <run>}"

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BEAGLE_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
cd "$SCRIPT_DIR"

# Resolve model name and budget
case "$MODEL_SHORT" in
  sonnet)
    MODEL_ID="claude-sonnet-4-6"
    BUDGET="5"
    ;;
  haiku)
    MODEL_ID="claude-haiku-4-5-20251001"
    BUDGET="2"
    ;;
  opus)
    MODEL_ID="claude-opus-4-6"
    BUDGET="15"
    ;;
  *)
    echo "Unknown model: $MODEL_SHORT (use 'sonnet', 'haiku', or 'opus')"
    exit 1
    ;;
esac

EXPT="e5f-${MODEL_SHORT}"
TRIAL_DIR="trials/${EXPT}-${TRACK}-run${RUN}"

echo "=== E5f: Smaller Model Trial ==="
echo "Model: $MODEL_ID"
echo "Track: $TRACK"
echo "Run: $RUN"
echo "Trial: $TRIAL_DIR/"
echo "Budget: \$$BUDGET"
echo ""

# Step 1: Setup trial directory
if [ -d "$TRIAL_DIR" ]; then
  echo "Trial dir already exists: $TRIAL_DIR"
  echo "Remove it first to re-run: rm -rf $TRIAL_DIR"
  exit 1
fi

mkdir -p "$TRIAL_DIR"

if [ "$TRACK" = "beagle" ]; then
  cp buggy-clean/beagle/*.rkt "$TRIAL_DIR/"
  PROMPT_FILE="prompts/beagle-agent-automated.md"
  TOOLS="Bash,Read,Edit"
elif [ "$TRACK" = "clojure" ]; then
  cp buggy-clean/clojure/*.clj "$TRIAL_DIR/"
  PROMPT_FILE="prompts/clojure-agent-automated.md"
  TOOLS="Bash,Read,Edit"
else
  echo "Unknown track: $TRACK (use 'beagle' or 'clojure')"
  exit 1
fi

# Record metadata
cat > "$TRIAL_DIR/metadata.json" <<EOF
{
  "experiment": "$EXPT",
  "track": "$TRACK",
  "run": $RUN,
  "model": "$MODEL_ID",
  "model_short": "$MODEL_SHORT",
  "budget_usd": $BUDGET,
  "beagle_version": "$(git -C "$BEAGLE_ROOT" describe --tags --always 2>/dev/null || echo 'unknown')",
  "commit": "$(git -C "$BEAGLE_ROOT" rev-parse HEAD 2>/dev/null || echo 'unknown')",
  "timestamp": "$(date -Iseconds)",
  "labeled_bugs": false
}
EOF

echo "Files copied: $(ls "$TRIAL_DIR/" | grep -c '\.\(rkt\|clj\)$')"
echo ""

# Step 2: Run agent
echo "--- Launching agent ($MODEL_ID) ---"
START_TIME=$(date +%s)

TASK_PROMPT="Fix all bugs in $TRIAL_DIR/. "
if [ "$TRACK" = "beagle" ]; then
  TASK_PROMPT+="Run bin/beagle-check-all $TRIAL_DIR/ first to see type errors, fix them all, then inspect for logic bugs."
else
  TASK_PROMPT+="Read each module and fix all bugs you can find. Check experiments/e5-event-pipeline/spec/domain.md for intended behavior."
fi

# Run claude with model, budget cap, and auto-permissions
# Pipe prompt via stdin to avoid shell quoting issues
echo "$TASK_PROMPT" | claude --model "$MODEL_ID" \
  --print \
  --dangerously-skip-permissions \
  --max-budget-usd "$BUDGET" \
  --tools "$TOOLS" \
  --system-prompt "$(cat "$PROMPT_FILE")" \
  --add-dir "$BEAGLE_ROOT" \
  > "$TRIAL_DIR/agent-output.txt" 2>&1 || true

END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

echo "Agent finished in ${ELAPSED}s"
echo ""

# Record timing
cat > "$TRIAL_DIR/timing.json" <<EOF
{
  "start": "$START_TIME",
  "end": "$END_TIME",
  "elapsed_seconds": $ELAPSED
}
EOF

# Step 3: Score
echo "--- Scoring ---"
bin/score-behavioral "$TRACK" "$TRIAL_DIR/"

echo ""
echo "=== Trial Complete ==="
echo "Model: $MODEL_ID"
echo "Track: $TRACK"
echo "Run: $RUN"
echo "Time: ${ELAPSED}s"
echo "Results: $TRIAL_DIR/"
