#!/usr/bin/env bash
set -euo pipefail

# Run an E5g trial: defunion + verify-after workflow
# Usage: bin/run-e5g-trial <track> <run-number>
# Example: bin/run-e5g-trial beagle 1
#          bin/run-e5g-trial clojure 2
#
# Always uses Opus. Beagle uses verify-after prompt.

TRACK="${1:?Usage: bin/run-e5g-trial <track> <run>}"
RUN="${2:?Usage: bin/run-e5g-trial <track> <run>}"

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BEAGLE_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
cd "$SCRIPT_DIR"

MODEL_ID="claude-opus-4-6"
BUDGET="15"
EXPT="e5g"
TRIAL_DIR="trials/${EXPT}-${TRACK}-run${RUN}"

echo "=== E5g: defunion + verify-after ==="
echo "Track: $TRACK"
echo "Run: $RUN"
echo "Trial: $TRIAL_DIR/"
echo "Budget: \$$BUDGET"
echo ""

# Step 1: Setup trial directory
if [ -d "$TRIAL_DIR" ]; then
  echo "Trial dir already exists: $TRIAL_DIR"
  echo "Remove it first to re-run: rm -rf $TRIAL_DIR"
  exit 1
fi

mkdir -p "$TRIAL_DIR"

if [ "$TRACK" = "beagle" ]; then
  cp buggy-clean/beagle/*.rkt "$TRIAL_DIR/"
  PROMPT_FILE="prompts/beagle-agent-verify-after.md"
  TOOLS="Bash,Read,Edit"
elif [ "$TRACK" = "clojure" ]; then
  cp buggy-clean/clojure/*.clj "$TRIAL_DIR/"
  PROMPT_FILE="prompts/clojure-agent-automated.md"
  TOOLS="Bash,Read,Edit"
else
  echo "Unknown track: $TRACK (use 'beagle' or 'clojure')"
  exit 1
fi

# Record metadata
cat > "$TRIAL_DIR/metadata.json" <<EOF
{
  "experiment": "$EXPT",
  "track": "$TRACK",
  "run": $RUN,
  "model": "$MODEL_ID",
  "budget_usd": $BUDGET,
  "prompt": "$(basename "$PROMPT_FILE")",
  "beagle_version": "$(git -C "$BEAGLE_ROOT" describe --tags --always 2>/dev/null || echo 'unknown')",
  "commit": "$(git -C "$BEAGLE_ROOT" rev-parse HEAD 2>/dev/null || echo 'unknown')",
  "timestamp": "$(date -Iseconds)"
}
EOF

echo "Files copied: $(ls "$TRIAL_DIR/" | grep -c '\.\(rkt\|clj\)$')"
echo ""

# Step 2: Build task prompt
if [ "$TRACK" = "beagle" ]; then
  # Pre-compute checker report so agent starts with full signal — no wasted tool call
  CHECKER_OUTPUT=$("$BEAGLE_ROOT/bin/beagle-check-all" "$TRIAL_DIR/" 2>&1 || true)
  TASK_PROMPT="Fix all bugs in $TRIAL_DIR/.

Here is the type checker output (already run for you):

\`\`\`
$CHECKER_OUTPUT
\`\`\`

Read experiments/e5-event-pipeline/spec/domain.md for intended behavior. Fix ALL errors above, and pay close attention to the note: lines — they flag semantic bugs (wrong accessor, missing field update) that are real bugs even though they type-check. Also inspect all source files for logic bugs the checker cannot catch (wrong filter direction, wrong arithmetic, wrong comparison)."
else
  TASK_PROMPT="Fix all bugs in $TRIAL_DIR/. Read each module and fix all bugs you can find. Check experiments/e5-event-pipeline/spec/domain.md for intended behavior."
fi

# Step 3: Run agent
echo "--- Launching agent (Opus) ---"
START_TIME=$(date +%s)

echo "$TASK_PROMPT" | claude --model "$MODEL_ID" \
  --print \
  --dangerously-skip-permissions \
  --max-budget-usd "$BUDGET" \
  --tools "$TOOLS" \
  --system-prompt "$(cat "$PROMPT_FILE")" \
  --add-dir "$BEAGLE_ROOT" \
  > "$TRIAL_DIR/agent-output.txt" 2>&1 || true

END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

echo "Agent finished in ${ELAPSED}s"
echo ""

# Record timing
cat > "$TRIAL_DIR/timing.json" <<EOF
{
  "start": "$START_TIME",
  "end": "$END_TIME",
  "elapsed_seconds": $ELAPSED
}
EOF

# Step 4: Score
echo "--- Scoring ---"
bin/score-behavioral "$TRACK" "$TRIAL_DIR/"

echo ""
echo "=== Trial Complete ==="
echo "Track: $TRACK"
echo "Run: $RUN"
echo "Time: ${ELAPSED}s"
echo "Results: $TRIAL_DIR/"
