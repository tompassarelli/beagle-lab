#!/usr/bin/env bash
set -euo pipefail

# Set up a trial directory from clean buggy files.
# Usage: bin/run-trial <track> <run-number>
# Example: bin/run-trial beagle 2

TRACK="${1:?Usage: bin/run-trial <track> <run>}"
RUN="${2:?Usage: bin/run-trial <track> <run>}"

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$SCRIPT_DIR"

EXPT="${3:-e5c}"
TRIAL_DIR="trials/${EXPT}-${TRACK}-run${RUN}"

if [ -d "$TRIAL_DIR" ]; then
  echo "Trial dir already exists: $TRIAL_DIR"
  echo "Remove it first if you want to re-run."
  exit 1
fi

mkdir -p "$TRIAL_DIR"

if [ "$TRACK" = "beagle" ]; then
  cp buggy-clean/beagle/*.rkt "$TRIAL_DIR/"
elif [ "$TRACK" = "clojure" ]; then
  cp buggy-clean/clojure/*.clj "$TRIAL_DIR/"
else
  echo "Unknown track: $TRACK (use 'beagle' or 'clojure')"
  exit 1
fi

# Record metadata
cat > "$TRIAL_DIR/metadata.json" <<EOF
{
  "experiment": "$EXPT",
  "track": "$TRACK",
  "run": $RUN,
  "beagle_version": "$(git -C ../.. describe --tags --always 2>/dev/null || echo 'unknown')",
  "commit": "$(git -C ../.. rev-parse HEAD 2>/dev/null || echo 'unknown')",
  "timestamp": "$(date -Iseconds)",
  "labeled_bugs": false
}
EOF

echo "=== Trial Setup ==="
echo "Track: $TRACK"
echo "Run: $RUN"
echo "Directory: $TRIAL_DIR/"
echo "Files: $(ls "$TRIAL_DIR/" | wc -l)"
echo ""
echo "Ready for agent. Score with: bin/score-trial $TRACK $TRIAL_DIR/"
