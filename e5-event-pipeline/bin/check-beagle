#!/usr/bin/env bash
set -euo pipefail

# Type-check all beagle modules in the given directory
# Usage: bin/check-beagle [dir]

DIR="${1:-golden/beagle}"
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BEAGLE_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

cd "$SCRIPT_DIR"

echo "Checking beagle modules in $DIR..."
"$BEAGLE_ROOT/bin/beagle-check-all" "$DIR/"
echo "All modules type-check successfully."
