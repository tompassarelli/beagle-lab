#!/usr/bin/env bash
set -euo pipefail

# Run a single experiment trial
# Usage: bin/run-experiment <experiment> <track> <run-number>
# Example: bin/run-experiment e5a beagle 1

EXPERIMENT="${1:?Usage: bin/run-experiment <experiment> <track> <run>}"
TRACK="${2:?Usage: bin/run-experiment <experiment> <track> <run>}"
RUN="${3:?Usage: bin/run-experiment <experiment> <track> <run>}"

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$SCRIPT_DIR"

RESPONSE_DIR="responses/${EXPERIMENT}-${TRACK}-run${RUN}"
mkdir -p "$RESPONSE_DIR"

echo "=== E5 Experiment ==="
echo "Experiment: $EXPERIMENT"
echo "Track: $TRACK"
echo "Run: $RUN"
echo "Output: $RESPONSE_DIR/"
echo "Beagle version: $(git -C ../.. describe --tags --always)"
echo "Timestamp: $(date -Iseconds)"
echo ""

# Record metadata
cat > "$RESPONSE_DIR/metadata.json" <<EOF
{
  "experiment": "$EXPERIMENT",
  "track": "$TRACK",
  "run": $RUN,
  "beagle_version": "$(git -C ../.. describe --tags --always)",
  "commit": "$(git -C ../.. rev-parse HEAD)",
  "timestamp": "$(date -Iseconds)"
}
EOF

case "$EXPERIMENT" in
  e5a)
    echo "Task: Fresh build from spec"
    echo "Spec: spec/e5a-fresh-build-${TRACK}.md"
    echo ""
    echo "The agent should read the spec and build all 8 modules."
    echo "Verify with: bin/check-beagle $RESPONSE_DIR/ (beagle) or clj verify/master.verify.clj (both)"
    ;;
  e5b)
    echo "Task: Schema evolution"
    echo "Spec: spec/e5b-schema-evolution.md"
    echo ""
    echo "Starting from golden reference, evolve OrderPlaced → OrderPlaced + OrderPriced"
    cp -r "golden/${TRACK}/"* "$RESPONSE_DIR/"
    echo "Golden reference copied to $RESPONSE_DIR/"
    ;;
  e5c)
    echo "Task: Bug detection"
    echo "Spec: spec/e5c-bug-detection.md"
    echo ""
    echo "Find and fix 40 injected bugs in the buggy reference."
    cp -r "buggy/${TRACK}/"* "$RESPONSE_DIR/"
    echo "Buggy reference copied to $RESPONSE_DIR/"
    ;;
  e5f)
    echo "Task: Smaller model bug detection"
    echo "Spec: spec/e5f-smaller-model.md"
    echo ""
    echo "Same 40 bugs, weaker model. Use bin/run-model-trial instead for automation."
    cp -r "buggy-clean/${TRACK}/"* "$RESPONSE_DIR/"
    echo "Buggy reference copied to $RESPONSE_DIR/"
    ;;
  *)
    echo "Unknown experiment: $EXPERIMENT"
    exit 1
    ;;
esac

echo ""
echo "Ready. Launch the agent against $RESPONSE_DIR/"
