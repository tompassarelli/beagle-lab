 ;; =============================================================================
+;; Worker Load Tracking
+;; =============================================================================
+
+;; build-worker-load-map: counts how many tasks have been assigned to each worker.
+(defn build-worker-load-map [(assignments : (Vec Assignment))] : (Map String Int)
+  (reduce (fn [(acc : (Map String Int)) (a : Assignment)]
+            (let [wid (assignment-worker-id a)
+                  current (get acc wid 0)]
+              (assoc acc wid (+ current 1))))
+          {} assignments))
+
+;; workers-within-limit: returns workers who have not yet reached their max-tasks limit.
+;; Workers with max-tasks=0 are always included (unlimited).
+(defn workers-within-limit [(workers : (Vec Worker))
+                             (worker-load-map : (Map String Int))] : (Vec Worker)
+  (filterv (fn [(w : Worker)]
+             (let [limit (worker-max-tasks w)
+                   cnt (get worker-load-map (worker-id w) 0)]
+               (or (= limit 0) (< cnt limit))))
+           workers))
+
