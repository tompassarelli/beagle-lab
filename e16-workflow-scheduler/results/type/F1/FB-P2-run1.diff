+;; check-resource-maintenance-v: verifies no required resource is in a
+;; maintenance window that overlaps the assignment window.
+;; Returns a Violation for the first conflicting resource, nil otherwise.
+(defn check-resource-maintenance-v [(assignment : Assignment)
+                                     (task : Task)
+                                     (resources : (Vec Resource))] : Violation?
+  (let [required-ids (set (task-resources task))
+        required-resources (filterv (fn [(r : Resource)]
+                                     (contains? required-ids (resource-id r)))
+                                   resources)
+        start (assignment-start-time assignment)
+        end (assignment-end-time assignment)]
+    (loop [i 0]
+      (if (>= i (count required-resources))
+        nil
+        (let [resource (nth required-resources i)
+              conflicting (first (filterv
+                                   (fn [(w : Window)]
+                                     (m/windows-overlap? start end
+                                                         (window-start w) (window-end w)))
+                                   (resource-maintenance-windows resource)))]
+          (if (some? conflicting)
+            (->Violation assignment
+                         (->ResourceInMaintenance (resource-id resource) conflicting))
+            (recur (+ i 1))))))))
+
