+
+def failure_reason_category(reason: "FailureReason") -> str:
+    from .types import GroupFailure, DependencyCycle
+    if isinstance(reason, GroupFailure):
+        return "group"
+    if isinstance(reason, DependencyCycle):
+        return "dependency"
+    return "scheduling"
+
+
+def failure_is_structural(reason: "FailureReason") -> bool:
+    from .types import GroupFailure
+    if isinstance(reason, GroupFailure):
