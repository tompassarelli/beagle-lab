#!/usr/bin/env bash
set -euo pipefail

# analyze-type-experiments — Summarize type-surface experiment results.
#
# Usage: bin/analyze-type-experiments [--experiment <name>]

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
EXPERIMENT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

EXPERIMENT="T1"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --experiment) EXPERIMENT="$2"; shift 2 ;;
    *) echo "Unknown arg: $1" >&2; exit 1 ;;
  esac
done

RESULT_DIR="$EXPERIMENT_DIR/results/type/$EXPERIMENT"

if [[ ! -d "$RESULT_DIR" ]]; then
  echo "No results at $RESULT_DIR" >&2
  exit 1
fi

python3 - "$RESULT_DIR" "$EXPERIMENT" <<'PYEOF'
import json, sys, os
from collections import defaultdict

result_dir = sys.argv[1]
experiment = sys.argv[2]

files = sorted(f for f in os.listdir(result_dir) if f.endswith('.json'))
if not files:
    print("No result files found.", file=sys.stderr)
    sys.exit(1)

results = []
for fname in files:
    with open(os.path.join(result_dir, fname)) as f:
        results.append(json.load(f))

print("=" * 60)
print(f" E16-T Type Surface Results: {experiment}")
print(f" {len(results)} trials")
print("=" * 60)

# ── Per-trial detail ────────────────────────────────────────

print()
print("--- Per-Trial Detail ---")
print(f"{'P':<4} {'Bug':<22} {'Run':<4} {'Quality':<14} {'Baseline':<10} {'Final':<10} {'Checks':<6} {'Time':<6}")

for d in sorted(results, key=lambda x: (x['profile'], x['bug'], x['run'])):
    p = d['profile']
    bug = d['bug']
    run = d['run']
    agent = d.get('agent', {})
    quality = agent.get('fix_quality', '?')
    bl = d['baseline']
    fn = d['final']
    chk = agent.get('check_calls', 0)
    dur = agent.get('duration_s', 0)

    if quality == 'type_caught':
        print(f"P{p:<3} {bug:<22} {run:<4} {'TYPE_CAUGHT':<14} {'-':<10} {'-':<10} {'-':<6} {'-':<6}")
    else:
        bl_str = f"{bl['passed']}/{bl['total']}"
        fn_str = f"{fn['passed']}/{fn['total']}"
        dur_str = f"{dur}s" if dur else "-"
        print(f"P{p:<3} {bug:<22} {run:<4} {quality:<14} {bl_str:<10} {fn_str:<10} {chk:<6} {dur_str:<6}")

# ── Aggregate by profile ────────────────────────────────────

print()
print("--- Per-Profile Summary ---")

by_profile = defaultdict(lambda: {
    'total': 0, 'type_caught': 0, 'clean_fix': 0, 'fix_regress': 0,
    'partial': 0, 'no_change': 0, 'worse': 0, 'no_run': 0,
    'check_calls': [], 'durations': [],
})

by_bug = defaultdict(lambda: defaultdict(lambda: {
    'runs': 0, 'quality': []
}))

for d in results:
    p = d['profile']
    bug = d['bug']
    agent = d.get('agent', {})
    quality = agent.get('fix_quality', 'no_run')

    by_profile[p]['total'] += 1
    by_profile[p][quality] = by_profile[p].get(quality, 0) + 1
    by_profile[p]['check_calls'].append(agent.get('check_calls', 0))
    by_profile[p]['durations'].append(agent.get('duration_s', 0))

    by_bug[bug][p]['runs'] += 1
    by_bug[bug][p]['quality'].append(quality)

QUALITY_ORDER = ['clean_fix', 'fix_regress', 'partial', 'no_change', 'worse', 'type_caught', 'no_run']

print(f"{'Profile':<8} {'Runs':<5} {'Clean':<7} {'Regress':<8} {'Partial':<8} {'Stuck':<6} {'Worse':<6} {'Caught':<7} {'FixRate':<8}")
for p in sorted(by_profile.keys()):
    s = by_profile[p]
    n = s['total']
    clean = s.get('clean_fix', 0)
    regress = s.get('fix_regress', 0)
    caught = s.get('type_caught', 0)
    fixed = clean + regress + caught
    rate = f"{fixed}/{n}" if n else "-"
    print(f"P{p:<7} {n:<5} {clean:<7} {regress:<8} {s.get('partial',0):<8} {s.get('no_change',0):<6} {s.get('worse',0):<6} {caught:<7} {rate:<8}")

# ── Per-bug breakdown ───────────────────────────────────────

print()
print("--- Per-Bug Breakdown ---")

profiles = sorted(by_profile.keys())
header = f"{'Bug':<22}"
for p in profiles:
    header += f"  {'P'+str(p):<12}"
print(header)

for bug in sorted(by_bug.keys()):
    row = f"{bug:<22}"
    for p in profiles:
        s = by_bug[bug][p]
        if s['runs'] == 0:
            row += f"  {'-':<12}"
        else:
            qualities = s['quality']
            caught = qualities.count('type_caught')
            clean = qualities.count('clean_fix')
            regress = qualities.count('fix_regress')
            partial = qualities.count('partial')
            worse = qualities.count('worse')
            nochange = qualities.count('no_change')

            if caught == len(qualities):
                label = "CAUGHT"
            elif clean + regress > 0:
                label = f"{clean}c/{regress}r/{len(qualities)}"
            elif partial > 0:
                label = f"{partial}p/{len(qualities)}"
            else:
                label = f"0/{len(qualities)}"
            row += f"  {label:<12}"
    print(row)

# ── Head-to-head ────────────────────────────────────────────

print()
print("--- Profile Head-to-Head ---")
for i in range(len(profiles)):
    for j in range(i+1, len(profiles)):
        pi, pj = profiles[i], profiles[j]
        si, sj = by_profile[pi], by_profile[pj]

        fi = si.get('clean_fix',0) + si.get('fix_regress',0) + si.get('type_caught',0)
        fj = sj.get('clean_fix',0) + sj.get('fix_regress',0) + sj.get('type_caught',0)
        ti, tj = si['total'], sj['total']
        ri = fi/ti*100 if ti else 0
        rj = fj/tj*100 if tj else 0
        delta = rj - ri
        d = f"+{delta:.0f}" if delta > 0 else f"{delta:.0f}"
        print(f"  P{pi} vs P{pj}: {fi}/{ti} ({ri:.0f}%) vs {fj}/{tj} ({rj:.0f}%) [{d}pp]")

print()
print("Quality key: clean_fix=all pass, fix_regress=fixed but broke others,")
print("  partial=improved, no_change=same as baseline, worse=more failures")
print("=" * 60)
PYEOF
