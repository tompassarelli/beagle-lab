#!/usr/bin/env bash
set -euo pipefail

# run-F1 — Launch the F1 feature-building experiment.
#
# SUPERSEDED by run-F3-corrected. F1 data is confounded: P0 agents
# received type checking at the default profile (P3 at the time) due
# to a missing --profile flag. See RESULTS.md "Confound" section.
#
# 2 features × 2 profiles (P0, P2) × N reps = 4N runs.
# Default: 1 rep = 4 runs. Order randomized.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

REPS=1
DRY_RUN=""
RESUME=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --reps) REPS="$2"; shift 2 ;;
    --dry-run) DRY_RUN="--dry-run"; shift ;;
    --resume) RESUME=true; shift ;;
    *) echo "Unknown arg: $1" >&2; exit 1 ;;
  esac
done

FEATURES=(A B)
PROFILES=(0 2)

TRIALS=()
for run in $(seq 1 "$REPS"); do
  for profile in "${PROFILES[@]}"; do
    for feature in "${FEATURES[@]}"; do
      TRIALS+=("$feature|$profile|$run")
    done
  done
done

SHUFFLED=($(printf '%s\n' "${TRIALS[@]}" | shuf))

TOTAL=${#SHUFFLED[@]}
DONE=0
SKIPPED=0

echo "=== F1: Feature Building Experiment ==="
echo "Features: ${#FEATURES[@]}  Profiles: ${#PROFILES[@]}  Reps: $REPS  Total: $TOTAL"
echo "Order: randomized"
echo ""

for trial in "${SHUFFLED[@]}"; do
  IFS='|' read -r feature profile run <<< "$trial"
  DONE=$((DONE + 1))

  RESULT_FILE="$SCRIPT_DIR/../results/type/F1/F${feature}-P${profile}-run${run}.json"
  if $RESUME && [[ -f "$RESULT_FILE" ]]; then
    SKIPPED=$((SKIPPED + 1))
    echo "[$DONE/$TOTAL] SKIP F${feature} P${profile} run${run}"
    continue
  fi

  echo ""
  echo "[$DONE/$TOTAL] Feature ${feature} P${profile} run${run}"
  echo "────────────────────────────────────────"

  "$SCRIPT_DIR/run-feature-experiment" \
    --feature "$feature" \
    --profile "$profile" \
    --run "$run" \
    --experiment F1 \
    $DRY_RUN

done

echo ""
echo "=== F1 Complete ==="
echo "Total: $TOTAL  Skipped: $SKIPPED  Ran: $((TOTAL - SKIPPED))"
