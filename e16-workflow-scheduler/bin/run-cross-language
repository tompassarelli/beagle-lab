#!/usr/bin/env bash
set -euo pipefail

# run-cross-language — Run one cross-language feature-building trial.
#
# Compares agent performance across language tracks using a shared
# behavioral oracle. Each track has its own build/test toolchain but
# the same feature spec and scoring.
#
# Usage:
#   bin/run-cross-language --track beagle --feature A --run 1
#   bin/run-cross-language --track python --feature A --run 1 [--dry-run]

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
EXPERIMENT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
ORACLE_DIR="$EXPERIMENT_DIR/verify/shared"
FEATURE_DIR="$EXPERIMENT_DIR/feature-tasks"
BEAGLE_BIN="/home/tom/code/beagle/bin/beagle"

TRACK=""
FEATURE=""
RUN=""
EXPERIMENT="XL1"
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --track)      TRACK="$2"; shift 2 ;;
    --feature)    FEATURE="$2"; shift 2 ;;
    --run)        RUN="$2"; shift 2 ;;
    --experiment) EXPERIMENT="$2"; shift 2 ;;
    --dry-run)    DRY_RUN=true; shift ;;
    *) echo "Unknown arg: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$TRACK" || -z "$FEATURE" || -z "$RUN" ]]; then
  echo "Usage: $(basename "$0") --track <beagle|python> --feature <A-E> --run <N>" >&2
  exit 1
fi

# Resolve feature directory
case "$FEATURE" in
  A) FEATURE_NAME="A-task-groups" ;;
  B) FEATURE_NAME="B-resource-maintenance" ;;
  C) FEATURE_NAME="C-worker-load-limits" ;;
  D) FEATURE_NAME="D-cost-budgets" ;;
  E) FEATURE_NAME="E-exclusive-resources" ;;
  *) echo "Unknown feature: $FEATURE (use A-E)" >&2; exit 1 ;;
esac

TASK_DIR="$FEATURE_DIR/$FEATURE_NAME"
RESULT_DIR="$EXPERIMENT_DIR/results/cross-language/$EXPERIMENT"
RESULT_FILE="$RESULT_DIR/${TRACK}-F${FEATURE}-run${RUN}.json"

TRIAL_ID=$(printf '%04x%04x' $RANDOM $RANDOM)
WORKSPACE="/tmp/xl-trial-${TRIAL_ID}"

mkdir -p "$RESULT_DIR"

echo "=== Cross-Language Trial ==="
echo "Track: ${TRACK}  Feature: ${FEATURE} (${FEATURE_NAME})  Run: ${RUN}  ID: ${TRIAL_ID}"
echo "Workspace: $WORKSPACE"
echo "Result: $RESULT_FILE"
echo ""

# ── Step 1: Set up workspace ──────────────────────────────────────────────

rm -rf "$WORKSPACE"
mkdir -p "$WORKSPACE/src"

# Copy feature spec (language-agnostic)
cp "$TASK_DIR/spec.md" "$WORKSPACE/feature-spec.md"

# Copy shared oracle cases for base regression testing
cp "$ORACLE_DIR/oracle.py" "$WORKSPACE/oracle.py"
cp "$ORACLE_DIR/cases.json" "$WORKSPACE/cases.json"

# ── Step 2: Track-specific setup ────────────────────────────────────────────

case "$TRACK" in
  beagle)
    GOLDEN_DIR="$EXPERIMENT_DIR/golden/beagle"
    cp "$GOLDEN_DIR/"*.bgl "$WORKSPACE/src/"
    mkdir -p "$WORKSPACE/tests"
    cp "$TASK_DIR/visible-oracle.clj" "$WORKSPACE/tests/feature-tests.clj" 2>/dev/null || true

    # Instrumented checker wrapper
    mkdir -p "$WORKSPACE/bin"
    cat > "$WORKSPACE/bin/beagle-check" <<WRAPEOF
#!/usr/bin/env bash
set -euo pipefail
LOG="$WORKSPACE/checker-log.jsonl"
START_NS=\$(date +%s%N 2>/dev/null || echo 0)
OUTPUT=\$("$BEAGLE_BIN" check --agent --profile 2 "\$@" 2>&1) || true
EXIT_CODE=\$?
END_NS=\$(date +%s%N 2>/dev/null || echo 0)
STDERR_LINES=\$(echo "\$OUTPUT" | wc -l)
ERROR_COUNT=\$(echo "\$OUTPUT" | head -1 | grep -oP '^\d+' || echo 0)
echo "\$OUTPUT" >&2
printf '{"ts":"%s","exit":%d,"stderr_lines":%d,"error_count":%s,"wall_ns":%d}\n' \\
  "\$(date -Iseconds)" "\$EXIT_CODE" "\$STDERR_LINES" "\$ERROR_COUNT" "\$((END_NS - START_NS))" >> "\$LOG"
exit \$EXIT_CODE
WRAPEOF
    chmod +x "$WORKSPACE/bin/beagle-check"

    cat > "$WORKSPACE/CLAUDE.md" <<AGENTEOF
# Task

Implement the feature described in \`feature-spec.md\`.

## Language: Beagle (\`#lang beagle/clj\`)

Source files are in \`src/\` — these are Beagle (.bgl) files that compile to Clojure.

## Source files
- \`src/types.bgl\` — type definitions
- \`src/graph.bgl\` — dependency graph
- \`src/matcher.bgl\` — worker matching
- \`src/scheduler.bgl\` — core scheduling algorithm
- \`src/errors.bgl\` — error types and descriptions
- \`src/validator.bgl\` — schedule validation

## Commands

Build (compile to Clojure):
\`\`\`
$BEAGLE_BIN build --warn --out $WORKSPACE/clj $WORKSPACE/src/
\`\`\`

Run feature tests:
\`\`\`
cd $WORKSPACE/clj && bb -cp . $WORKSPACE/tests/feature-tests.clj
\`\`\`

Type check (errors only, fast):
\`\`\`
$WORKSPACE/bin/beagle-check $WORKSPACE/src/
\`\`\`

## Workflow
1. Read \`feature-spec.md\` to understand the feature requirements.
2. Read the existing source files to understand the codebase.
3. Implement the feature across all affected files.
4. Build and run feature tests. Iterate until all tests pass.
5. Run the type checker. Fix any exhaustive-match errors (these point to match sites you missed). Iterate until 0 errors.

## Rules
- Only edit files in \`src/\`.
- Do not modify test files.
- Always rebuild before running tests.
- Make sure existing behavior is preserved (the feature extends, not replaces).
- After tests pass, run the type checker to catch missed match sites — it reports only real errors.
AGENTEOF
    ;;

  python)
    GOLDEN_DIR="$EXPERIMENT_DIR/golden/python"
    cp -r "$GOLDEN_DIR/"* "$WORKSPACE/src/"

    cat > "$WORKSPACE/CLAUDE.md" <<AGENTEOF
# Task

Implement the feature described in \`feature-spec.md\`.

## Language: Python (with type annotations)

## Source files (in \`src/\`)
- \`types.py\` — dataclass definitions
- \`graph.py\` — dependency graph
- \`matcher.py\` — worker matching
- \`scheduler.py\` — core scheduling algorithm
- \`validator.py\` — schedule validation
- \`__main__.py\` — JSON CLI adapter

## Commands

Run tests:
\`\`\`
cd $WORKSPACE && python3 -m pytest src/ -v
\`\`\`

Type check:
\`\`\`
cd $WORKSPACE && python3 -m mypy src/ --strict
\`\`\`

Run scheduler (JSON stdin/stdout):
\`\`\`
echo '{"tasks":[],"workers":[],"resources":[]}' | python3 -m src
\`\`\`

## Workflow
1. Read \`feature-spec.md\` to understand the feature requirements.
2. Read the existing source files to understand the codebase.
3. Implement the feature across all affected files.
4. Run tests. Iterate until all tests pass.
5. Run mypy. Fix any type errors.

## Rules
- Only edit files in \`src/\`.
- Make sure existing behavior is preserved (the feature extends, not replaces).
AGENTEOF
    ;;

  *) echo "Unknown track: $TRACK (use beagle, python)" >&2; exit 1 ;;
esac

echo "Workspace ready: $WORKSPACE"

# ── Step 3: Baseline checks ──────────────────────────────────────────────

case "$TRACK" in
  beagle)
    BASELINE_CHECK=$("$BEAGLE_BIN" check --profile 2 "$GOLDEN_DIR/" 2>&1) || true
    BASELINE_ERRORS=$(echo "$BASELINE_CHECK" | grep -oP '\d+ error' | grep -oP '^\d+' || echo 0)
    echo "Baseline type errors: $BASELINE_ERRORS"
    ;;
  python)
    BASELINE_ERRORS=0
    echo "Baseline: Python (no pre-check)"
    ;;
esac

# ── Step 4: Launch agent ─────────────────────────────────────────────────

AGENT_DURATION=0
VISIBLE_PASSED=0
VISIBLE_TOTAL=0
ORACLE_PASSED=0
ORACLE_TOTAL=0
FINAL_TYPE_ERRORS=0
FIX_QUALITY="no_run"

if $DRY_RUN; then
  echo "[DRY RUN] Workspace ready at $WORKSPACE"
else
  echo "Launching Claude Code agent..."
  AGENT_START=$(date +%s)

  AGENT_OUTPUT=$(cd "$WORKSPACE" && timeout 600 claude --print \
    --dangerously-skip-permissions \
    --no-session-persistence \
    --model sonnet \
    -p "Read CLAUDE.md and follow the instructions. Implement the feature described in feature-spec.md. Make all tests pass while preserving existing behavior." \
    2>&1) || true

  AGENT_END=$(date +%s)
  AGENT_DURATION=$((AGENT_END - AGENT_START))

  echo "$AGENT_OUTPUT" > "$WORKSPACE/agent-transcript.txt"

  # ── Step 5: Post-agent measurement ──────────────────────────────────────

  case "$TRACK" in
    beagle)
      # Build
      "$BEAGLE_BIN" build --warn --out "$WORKSPACE/clj" "$WORKSPACE/src/" >/dev/null 2>&1 || true

      # Final type check
      FINAL_CHECK=$("$BEAGLE_BIN" check --profile 2 "$WORKSPACE/src/" 2>&1) || true
      FINAL_TYPE_ERRORS=$(echo "$FINAL_CHECK" | grep -oP '\d+ error' | grep -oP '^\d+' || echo 0)

      # Visible oracle
      if [[ -f "$WORKSPACE/tests/feature-tests.clj" ]] && [[ -d "$WORKSPACE/clj/scheduler" ]]; then
        VISIBLE_OUT=$(cd "$WORKSPACE/clj" && timeout 60 bb -cp . "$WORKSPACE/tests/feature-tests.clj" 2>&1) || true
        VISIBLE_PASSED=$(echo "$VISIBLE_OUT" | grep -c '^PASS:' || true)
        VISIBLE_TOTAL=$(grep -c '(run-test "' "$WORKSPACE/tests/feature-tests.clj" || true)
      fi

      # Hidden oracle for scoring
      if [[ -d "$WORKSPACE/clj/scheduler" ]] && [[ -f "$TASK_DIR/hidden-oracle.clj" ]]; then
        HIDDEN_OUT=$(cd "$WORKSPACE/clj" && timeout 60 bb -cp . "$TASK_DIR/hidden-oracle.clj" 2>&1) || true
        ORACLE_PASSED=$(echo "$HIDDEN_OUT" | grep -c '^PASS:' || true)
        ORACLE_TOTAL=$(grep -c '(run-test "' "$TASK_DIR/hidden-oracle.clj" || true)
      fi
      ;;

    python)
      # mypy
      FINAL_CHECK=$(cd "$WORKSPACE" && python3 -m mypy src/ --strict 2>&1) || true
      if echo "$FINAL_CHECK" | grep -q "Success"; then
        FINAL_TYPE_ERRORS=0
      else
        FINAL_TYPE_ERRORS=$(echo "$FINAL_CHECK" | grep -c "error:" || true)
        FINAL_TYPE_ERRORS=${FINAL_TYPE_ERRORS:-0}
      fi

      # pytest
      PYTEST_OUT=$(cd "$WORKSPACE" && timeout 120 python3 -m pytest src/ -v --tb=short 2>&1) || true
      VISIBLE_PASSED=$(echo "$PYTEST_OUT" | grep -oP '\d+ passed' | grep -oP '^\d+' || echo 0)
      VISIBLE_TOTAL=$((VISIBLE_PASSED + $(echo "$PYTEST_OUT" | grep -oP '\d+ failed' | grep -oP '^\d+' || echo 0)))

      # Shared oracle via stdin/stdout
      ORACLE_OUT=$(cd "$EXPERIMENT_DIR" && python3 "$ORACLE_DIR/oracle.py" \
        --cmd "cd $WORKSPACE && python3 -m src" \
        --json 2>&1) || true
      if [[ -n "$ORACLE_OUT" ]]; then
        ORACLE_PASSED=$(echo "$ORACLE_OUT" | python3 -c "import sys,json; print(json.load(sys.stdin)['passed'])" 2>/dev/null || echo 0)
        ORACLE_TOTAL=$(echo "$ORACLE_OUT" | python3 -c "import sys,json; print(json.load(sys.stdin)['total'])" 2>/dev/null || echo 0)
      fi
      ;;
  esac

  # Diff
  diff -ru "$GOLDEN_DIR/" "$WORKSPACE/src/" > "$WORKSPACE/final.diff" 2>/dev/null || true

  echo "Type errors: $FINAL_TYPE_ERRORS (baseline: ${BASELINE_ERRORS:-0})"
  echo "Visible tests: ${VISIBLE_PASSED}/${VISIBLE_TOTAL}"
  echo "Shared oracle: ${ORACLE_PASSED}/${ORACLE_TOTAL}"

  # ── Step 6: Score quality ──────────────────────────────────────────────

  if [[ "$ORACLE_TOTAL" -gt 0 && "$ORACLE_PASSED" -eq "$ORACLE_TOTAL" ]]; then
    if [[ "$VISIBLE_TOTAL" -gt 0 && "$VISIBLE_PASSED" -lt "$VISIBLE_TOTAL" ]]; then
      FIX_QUALITY="oracle_complete_visible_incomplete"
    else
      FIX_QUALITY="complete"
    fi
  elif [[ "$ORACLE_TOTAL" -gt 0 && "$ORACLE_PASSED" -gt 0 ]]; then
    FIX_QUALITY="partial"
  elif [[ "$VISIBLE_TOTAL" -eq 0 && "$ORACLE_TOTAL" -eq 0 ]]; then
    FIX_QUALITY="broken_build"
  elif [[ "$VISIBLE_TOTAL" -gt 0 && "$VISIBLE_PASSED" -eq "$VISIBLE_TOTAL" ]]; then
    FIX_QUALITY="visible_only"
  elif [[ "$VISIBLE_TOTAL" -gt 0 ]]; then
    FIX_QUALITY="visible_incomplete"
  else
    FIX_QUALITY="broken_build"
  fi

  echo "Quality: ${FIX_QUALITY}  Duration: ${AGENT_DURATION}s"
fi

# ── Step 7: Write result JSON ────────────────────────────────────────────

cat > "$RESULT_FILE" <<EOF
{
  "experiment": "$EXPERIMENT",
  "track": "$TRACK",
  "feature": "$FEATURE",
  "feature_name": "$FEATURE_NAME",
  "run": $RUN,
  "trial_id": "$TRIAL_ID",
  "visible_tests": {
    "total": $VISIBLE_TOTAL,
    "passed": $VISIBLE_PASSED
  },
  "shared_oracle": {
    "total": $ORACLE_TOTAL,
    "passed": $ORACLE_PASSED
  },
  "final_type_errors": $FINAL_TYPE_ERRORS,
  "baseline_type_errors": ${BASELINE_ERRORS:-0},
  "fix_quality": "$FIX_QUALITY",
  "duration_s": $AGENT_DURATION,
  "timestamp": "$(date -Iseconds)",
  "workspace": "$WORKSPACE"
}
EOF

# ── Step 8: Append checker instrumentation ────────────────────────────────

CHECKER_LOG="$WORKSPACE/checker-log.jsonl"
if [[ -f "$CHECKER_LOG" ]]; then
  INVOCATIONS=$(wc -l < "$CHECKER_LOG")
  echo "Checker invocations: $INVOCATIONS"
  python3 -c "
import json
with open('$RESULT_FILE') as f: result = json.load(f)
invocations = []
with open('$CHECKER_LOG') as f:
    for line in f:
        invocations.append(json.loads(line.strip()))
result['checker_invocations'] = len(invocations)
result['checker_log'] = invocations
with open('$RESULT_FILE', 'w') as f: json.dump(result, f, indent=2)
" 2>/dev/null || true
  cp "$CHECKER_LOG" "$RESULT_DIR/${TRACK}-F${FEATURE}-run${RUN}-checker.jsonl"
fi

if [[ -f "$WORKSPACE/final.diff" ]]; then
  cp "$WORKSPACE/final.diff" "$RESULT_DIR/${TRACK}-F${FEATURE}-run${RUN}.diff"
fi

echo "Result: $RESULT_FILE"
