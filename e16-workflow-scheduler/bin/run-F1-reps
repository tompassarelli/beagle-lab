#!/usr/bin/env bash
set -euo pipefail

# run-F1-reps — Feature A structural replication experiment.
#
# SUPERSEDED by run-F3-corrected. F1-reps data is confounded: P0 agents
# received type checking at the default profile (P2) due to a missing
# --profile flag. See RESULTS.md "Confound: P0 Profile Leakage" section.
#
# Runs Feature A + 3 structural variants (C, D, E) × 2 profiles (P0, P2).
# Same coordination complexity class, different domain surfaces.
# Order randomized to prevent ordering effects.
#
# 4 features × 2 profiles × 1 rep = 8 runs.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

REPS=1
DRY_RUN=""
RESUME=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --reps) REPS="$2"; shift 2 ;;
    --dry-run) DRY_RUN="--dry-run"; shift ;;
    --resume) RESUME=true; shift ;;
    *) echo "Unknown arg: $1" >&2; exit 1 ;;
  esac
done

FEATURES=(A C D E)
PROFILES=(0 2)

TRIALS=()
for run in $(seq 1 "$REPS"); do
  for profile in "${PROFILES[@]}"; do
    for feature in "${FEATURES[@]}"; do
      TRIALS+=("$feature|$profile|$run")
    done
  done
done

SHUFFLED=($(printf '%s\n' "${TRIALS[@]}" | shuf))

TOTAL=${#SHUFFLED[@]}
DONE=0
SKIPPED=0

echo "=== F1-reps: Feature A Structural Replication ==="
echo "Features: ${FEATURES[*]}  Profiles: ${PROFILES[*]}  Reps: $REPS  Total: $TOTAL"
echo "Order: randomized"
echo ""

for trial in "${SHUFFLED[@]}"; do
  IFS='|' read -r feature profile run <<< "$trial"
  DONE=$((DONE + 1))

  RESULT_FILE="$SCRIPT_DIR/../results/type/F1-reps/F${feature}-P${profile}-run${run}.json"
  if $RESUME && [[ -f "$RESULT_FILE" ]]; then
    SKIPPED=$((SKIPPED + 1))
    echo "[$DONE/$TOTAL] SKIP F${feature} P${profile} run${run}"
    continue
  fi

  echo ""
  echo "[$DONE/$TOTAL] Feature ${feature} P${profile} run${run}"
  echo "────────────────────────────────────────"

  "$SCRIPT_DIR/run-feature-experiment" \
    --feature "$feature" \
    --profile "$profile" \
    --run "$run" \
    --experiment F1-reps \
    $DRY_RUN

done

echo ""
echo "=== F1-reps Complete ==="
echo "Total: $TOTAL  Skipped: $SKIPPED  Ran: $((TOTAL - SKIPPED))"
