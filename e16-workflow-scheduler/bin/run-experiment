#!/usr/bin/env bash
set -euo pipefail

# run-experiment â€” Full orchestration for a single bug-fix trial.
#
# Usage: bin/run-experiment <track> <bug_id> [--run <N>]
#
# Steps:
#   1. Create workspace at /tmp/e16-<track>-<bug_id>-<run>/
#   2. Setup bug (copy golden + apply patch)
#   3. Run oracle baseline (should have failures)
#   4. Wait for agent repair (user presses Enter)
#   5. Run oracle final
#   6. Record results

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
EXPERIMENT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
RESULTS_DIR="$EXPERIMENT_DIR/results"

usage() {
  echo "Usage: $(basename "$0") <track> <bug_id> [--run <N>]"
  echo "Tracks: beagle, python"
  exit 1
}

if [[ $# -lt 2 ]]; then
  usage
fi

TRACK="$1"
BUG_ID="$2"
shift 2

RUN=1
while [[ $# -gt 0 ]]; do
  case "$1" in
    --run)
      RUN="$2"
      shift 2
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage
      ;;
  esac
done

WORKSPACE="/tmp/e16-${TRACK}-${BUG_ID}-${RUN}"
PREFIX="${TRACK}-${BUG_ID}-${RUN}"

echo "================================================================"
echo "E16 Experiment: track=$TRACK  bug=$BUG_ID  run=$RUN"
echo "Workspace: $WORKSPACE"
echo "================================================================"
echo ""

# ---------------------------------------------------------------------------
# 1-2. Setup workspace with bug
# ---------------------------------------------------------------------------

if [[ -d "$WORKSPACE" ]]; then
  echo "Removing existing workspace ..."
  rm -rf "$WORKSPACE"
fi

"$SCRIPT_DIR/setup-bug" "$TRACK" "$BUG_ID" "$WORKSPACE"
echo ""

# ---------------------------------------------------------------------------
# 3. Run baseline oracle
# ---------------------------------------------------------------------------

echo "Running baseline oracle ..."
BASELINE_JSON=$("$SCRIPT_DIR/run-oracle" "$TRACK" "$WORKSPACE" --json 2>/dev/null) || true
echo "Baseline: $BASELINE_JSON"
echo "$BASELINE_JSON" > "$RESULTS_DIR/${PREFIX}-baseline.json"
echo ""

# ---------------------------------------------------------------------------
# 4. Agent repair phase
# ---------------------------------------------------------------------------

echo "================================================================"
echo "AGENT REPAIR PHASE"
echo "================================================================"
echo ""
echo "Point your agent at the workspace:"
echo ""
case "$TRACK" in
  beagle)
    echo "  Workspace (source):  $WORKSPACE"
    echo "  Workspace (clj):     $WORKSPACE/_clj"
    echo "  Files to edit:       $WORKSPACE/*.bgl"
    echo ""
    echo "  After editing, rebuild with:"
    echo "    cd $WORKSPACE && /home/tom/code/beagle/bin/beagle build . --out $WORKSPACE/_clj"
    echo ""
    echo "  Test with:"
    echo "    cd $WORKSPACE/_clj && bb -cp . $EXPERIMENT_DIR/verify/beagle/oracle.clj"
    ;;
  python)
    echo "  Workspace:     $WORKSPACE"
    echo "  Package dir:   $WORKSPACE/python/"
    echo "  Files to edit: $WORKSPACE/python/*.py"
    echo ""
    echo "  Test with:"
    echo "    PYTHONPATH=$WORKSPACE python -m pytest $EXPERIMENT_DIR/verify/python/test_oracle.py -v --tb=short --noconftest"
    ;;
esac
echo ""
echo "Press Enter when the agent has finished repairs ..."
read -r

# ---------------------------------------------------------------------------
# 5-6. Run final oracle and record results
# ---------------------------------------------------------------------------

echo "Running final oracle ..."
FINAL_JSON=$("$SCRIPT_DIR/run-oracle" "$TRACK" "$WORKSPACE" --json 2>/dev/null) || true
echo "Final: $FINAL_JSON"
echo "$FINAL_JSON" > "$RESULTS_DIR/${PREFIX}-final.json"
echo ""

# ---------------------------------------------------------------------------
# 7. Compute summary
# ---------------------------------------------------------------------------

# Extract fields from JSON (lightweight â€” no jq dependency)
json_field() {
  local json="$1" field="$2"
  echo "$json" | grep -oP "\"$field\":\s*\K[0-9]+" || echo 0
}

B_TOTAL=$(json_field "$BASELINE_JSON" "total")
B_PASSED=$(json_field "$BASELINE_JSON" "passed")
B_FAILED=$(json_field "$BASELINE_JSON" "failed")

F_TOTAL=$(json_field "$FINAL_JSON" "total")
F_PASSED=$(json_field "$FINAL_JSON" "passed")
F_FAILED=$(json_field "$FINAL_JSON" "failed")

ASSERTIONS_RESTORED=$((F_PASSED - B_PASSED))
if [[ $ASSERTIONS_RESTORED -lt 0 ]]; then
  ASSERTIONS_RESTORED=0
fi

# Regressions: tests that passed in baseline but fail in final
REGRESSIONS=$((B_PASSED - F_PASSED))
if [[ $REGRESSIONS -lt 0 ]]; then
  REGRESSIONS=0
fi

ASSERTIONS_REGRESSED=$REGRESSIONS

if [[ "$F_FAILED" -eq 0 && "$F_TOTAL" -gt 0 ]]; then
  FIXED="true"
else
  FIXED="false"
fi

cat > "$RESULTS_DIR/${PREFIX}-summary.json" <<EOF
{
  "track": "$TRACK",
  "bug_id": "$BUG_ID",
  "run": $RUN,
  "baseline": {"total": $B_TOTAL, "passed": $B_PASSED, "failed": $B_FAILED},
  "final": {"total": $F_TOTAL, "passed": $F_PASSED, "failed": $F_FAILED},
  "fixed": $FIXED,
  "regressions": $REGRESSIONS,
  "assertions_restored": $ASSERTIONS_RESTORED,
  "assertions_regressed": $ASSERTIONS_REGRESSED
}
EOF

echo "================================================================"
echo "RESULTS"
echo "================================================================"
cat "$RESULTS_DIR/${PREFIX}-summary.json"
echo ""
echo "Summary written to: $RESULTS_DIR/${PREFIX}-summary.json"
