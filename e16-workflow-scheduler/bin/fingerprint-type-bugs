#!/usr/bin/env bash
set -euo pipefail

# fingerprint-type-bugs — Check which bugs the type checker catches at each profile.
#
# Usage: bin/fingerprint-type-bugs [--profile <N>]
#
# Without --profile: tests all profiles (0-3) × all bugs (01-10).
# With --profile: tests only that profile.
#
# No agent involvement — pure static analysis.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
EXPERIMENT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
GOLDEN_DIR="$EXPERIMENT_DIR/golden/beagle"
TYPE_BUGS_DIR="$EXPERIMENT_DIR/type-bugs"
VERIFY_DIR="$EXPERIMENT_DIR/verify"
BEAGLE_BIN="/home/tom/code/beagle/bin/beagle"

PROFILES=(0 1 2 3)

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile) PROFILES=("$2"); shift 2 ;;
    *) echo "Unknown arg: $1" >&2; exit 1 ;;
  esac
done

WORKSPACE="/tmp/e16t-fingerprint"

echo "=== Type Bug Fingerprints ==="
echo ""
printf "%-20s" "Bug"
for p in "${PROFILES[@]}"; do
  printf " %-12s" "P$p"
done
printf " %-10s" "Oracle"
echo ""
printf "%-20s" "---"
for p in "${PROFILES[@]}"; do
  printf " %-12s" "---"
done
printf " %-10s" "---"
echo ""

for bugdir in "$TYPE_BUGS_DIR"/*/; do
  bugname=$(basename "$bugdir")
  printf "%-20s" "$bugname"

  # Test each profile
  for p in "${PROFILES[@]}"; do
    # Golden baseline: how many errors does the CLEAN code have at this profile?
    GOLDEN_OUT=$("$BEAGLE_BIN" check --profile "$p" "$GOLDEN_DIR/" 2>&1) || true
    GOLDEN_ERRS=$(echo "$GOLDEN_OUT" | grep -oP '\d+ error' | grep -oP '^\d+' || echo 0)

    rm -rf "$WORKSPACE"
    mkdir -p "$WORKSPACE/src"
    cp "$GOLDEN_DIR/"*.bgl "$WORKSPACE/src/"
    bash "$bugdir/apply.sh" "$WORKSPACE/src" 2>/dev/null

    CHECK_OUT=$("$BEAGLE_BIN" check --profile "$p" "$WORKSPACE/src/" 2>&1) || true
    BUGGY_ERRS=$(echo "$CHECK_OUT" | grep -oP '\d+ error' | grep -oP '^\d+' || echo 0)

    NEW_ERRS=$((BUGGY_ERRS - GOLDEN_ERRS))
    if [[ $NEW_ERRS -gt 0 ]]; then
      printf " %-12s" "CAUGHT(+$NEW_ERRS)"
    else
      printf " %-12s" "pass"
    fi
  done

  # Always build with --warn for oracle testing
  rm -rf "$WORKSPACE"
  mkdir -p "$WORKSPACE/src"
  cp "$GOLDEN_DIR/"*.bgl "$WORKSPACE/src/"
  bash "$bugdir/apply.sh" "$WORKSPACE/src" 2>/dev/null
  "$BEAGLE_BIN" build --warn --out "$WORKSPACE/clj" "$WORKSPACE/src/" >/dev/null 2>&1 || true

  if [[ -d "$WORKSPACE/clj/scheduler" ]]; then
    ORACLE_OUT=$(cd "$WORKSPACE/clj" && timeout 30 bb -cp . "$VERIFY_DIR/beagle/oracle.clj" 2>&1) || true
    PASSES=$(echo "$ORACLE_OUT" | grep -c '^PASS:' || true)
    CRASHES=$(echo "$ORACLE_OUT" | grep -c 'Assert failed' || true)
    printf " %-10s" "${PASSES}p/${CRASHES}f"
  else
    printf " %-10s" "no-build"
  fi

  echo ""
done

rm -rf "$WORKSPACE"

echo ""
echo "CAUGHT = type checker rejects the code"
echo "pass = code compiles (bug only detectable at runtime)"
echo "Oracle: Np/Mf = N tests passed before M assertion failures"
