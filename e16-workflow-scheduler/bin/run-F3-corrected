#!/usr/bin/env bash
set -euo pipefail

# run-F3-corrected — Re-run feature experiments with corrected P0/P2 separation.
#
# F1 and F1-reps had a confound: P0 agents received type checking due to
# a template bug (missing --profile flag defaulted to P2/P3). F3 uses the
# corrected run-feature-experiment which:
#   - P0: no checker commands at all
#   - P2: beagle check --agent --profile 2 (post-test verification)
#
# 4 features × 2 profiles × N reps, randomized order.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

REPS=1
DRY_RUN=""
RESUME=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --reps) REPS="$2"; shift 2 ;;
    --dry-run) DRY_RUN="--dry-run"; shift ;;
    --resume) RESUME=true; shift ;;
    *) echo "Unknown arg: $1" >&2; exit 1 ;;
  esac
done

FEATURES=(A C D E)
PROFILES=(0 2)

TRIALS=()
for run in $(seq 1 "$REPS"); do
  for profile in "${PROFILES[@]}"; do
    for feature in "${FEATURES[@]}"; do
      TRIALS+=("$feature|$profile|$run")
    done
  done
done

SHUFFLED=($(printf '%s\n' "${TRIALS[@]}" | shuf))

TOTAL=${#SHUFFLED[@]}
DONE=0
SKIPPED=0

echo "=== F3-corrected: True P0 vs Clean P2 ==="
echo "Features: ${FEATURES[*]}  Profiles: ${PROFILES[*]}  Reps: $REPS  Total: $TOTAL"
echo "Order: randomized"
echo ""

for trial in "${SHUFFLED[@]}"; do
  IFS='|' read -r feature profile run <<< "$trial"
  DONE=$((DONE + 1))

  RESULT_FILE="$SCRIPT_DIR/../results/type/F3-corrected/F${feature}-P${profile}-run${run}.json"
  if $RESUME && [[ -f "$RESULT_FILE" ]]; then
    SKIPPED=$((SKIPPED + 1))
    echo "[$DONE/$TOTAL] SKIP F${feature} P${profile} run${run}"
    continue
  fi

  echo ""
  echo "[$DONE/$TOTAL] Feature ${feature} P${profile} run${run}"
  echo "────────────────────────────────────────"

  "$SCRIPT_DIR/run-feature-experiment" \
    --feature "$feature" \
    --profile "$profile" \
    --run "$run" \
    --experiment F3-corrected \
    $DRY_RUN

done

echo ""
echo "=== F3-corrected Complete ==="
echo "Total: $TOTAL  Skipped: $SKIPPED  Ran: $((TOTAL - SKIPPED))"
