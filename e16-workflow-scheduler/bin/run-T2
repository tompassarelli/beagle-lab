#!/usr/bin/env bash
set -euo pipefail

# run-T2 — Launch the T2 diagnostic noise experiment.
#
# Usage: bin/run-T2 [--reps <N>] [--dry-run] [--resume]
#
# 10 bugs × 2 modes (--agent vs default) × N reps (default 2) = 40 runs.
# Profile fixed at P2. Trial order randomized.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

REPS=2
DRY_RUN=""
RESUME=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --reps) REPS="$2"; shift 2 ;;
    --dry-run) DRY_RUN="--dry-run"; shift ;;
    --resume) RESUME=true; shift ;;
    *) echo "Unknown arg: $1" >&2; exit 1 ;;
  esac
done

BUGS=(01-window-overlap 02-retry-count 03-priority-reversed 04-id-swap 05-empty-list 06-missing-match 07-edges-reversed 08-tiebreak-order 09-error-swallowed 10-wrong-field)
MODES=("agent" "default")

# Build trial list, then shuffle
TRIALS=()
for run in $(seq 1 "$REPS"); do
  for mode in "${MODES[@]}"; do
    for bug in "${BUGS[@]}"; do
      TRIALS+=("$mode|$bug|$run")
    done
  done
done

SHUFFLED=($(printf '%s\n' "${TRIALS[@]}" | shuf))

TOTAL=${#SHUFFLED[@]}
DONE=0
SKIPPED=0

echo "=== T2: Diagnostic Noise ==="
echo "Bugs: ${#BUGS[@]}  Modes: ${#MODES[@]}  Reps: $REPS  Total: $TOTAL"
echo "Profile: P2 (fixed)  Order: randomized"
echo ""

for trial in "${SHUFFLED[@]}"; do
  IFS='|' read -r mode bug run <<< "$trial"
  DONE=$((DONE + 1))

  RESULT_FILE="$SCRIPT_DIR/../results/type/T2/P2-${mode}-bug${bug}-run${run}.json"
  if $RESUME && [[ -f "$RESULT_FILE" ]]; then
    SKIPPED=$((SKIPPED + 1))
    echo "[$DONE/$TOTAL] SKIP ${mode} ${bug} run${run}"
    continue
  fi

  echo ""
  echo "[$DONE/$TOTAL] mode=${mode} ${bug} run${run}"
  echo "────────────────────────────────────────"

  "$SCRIPT_DIR/run-type-experiment" \
    --profile 2 \
    --bug "$bug" \
    --run "$run" \
    --check-mode "$mode" \
    --experiment "T2" \
    $DRY_RUN

done

echo ""
echo "=== T2 Complete ==="
echo "Total: $TOTAL  Skipped: $SKIPPED  Ran: $((TOTAL - SKIPPED))"
echo ""
echo "Analyze:"
echo "  bin/analyze-type-experiments --experiment T2"
