#!/usr/bin/env bash
set -euo pipefail

# run-T1 — Launch the T1 profile comparison experiment.
#
# Usage: bin/run-T1 [--reps <N>] [--dry-run] [--resume] [--all]
#
# Default (lean): 3 bugs × 4 profiles × 1 rep = 12 runs.
# --all: 10 bugs × 4 profiles × N reps.
# --resume: skip trials that already have result files.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

REPS=1
DRY_RUN=""
RESUME=false
BUGS_MODE="lean"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --reps) REPS="$2"; shift 2 ;;
    --dry-run) DRY_RUN="--dry-run"; shift ;;
    --resume) RESUME=true; shift ;;
    --all) BUGS_MODE="all"; shift ;;
    *) echo "Unknown arg: $1" >&2; exit 1 ;;
  esac
done

if [[ "$BUGS_MODE" == "all" ]]; then
  BUGS=(01-window-overlap 02-retry-count 03-priority-reversed 04-id-swap 05-empty-list 06-missing-match 07-edges-reversed 08-tiebreak-order 09-error-swallowed 10-wrong-field)
else
  # 3 representative bugs: logic (01), type-adjacent (04), graph (07)
  # All checker-invisible across P0-P3, so agent always runs
  BUGS=(01-window-overlap 04-id-swap 07-edges-reversed)
fi
PROFILES=(0 1 2 3)

# Build trial list, then randomize order to avoid systematic bias
TRIALS=()
for run in $(seq 1 "$REPS"); do
  for profile in "${PROFILES[@]}"; do
    for bug in "${BUGS[@]}"; do
      TRIALS+=("$profile|$bug|$run")
    done
  done
done

# Shuffle trial order
SHUFFLED=($(printf '%s\n' "${TRIALS[@]}" | shuf))

TOTAL=${#SHUFFLED[@]}
DONE=0
SKIPPED=0

echo "=== T1: Profile Comparison ($BUGS_MODE) ==="
echo "Bugs: ${#BUGS[@]}  Profiles: ${#PROFILES[@]}  Reps: $REPS  Total: $TOTAL"
echo "Order: randomized"
echo ""

for trial in "${SHUFFLED[@]}"; do
  IFS='|' read -r profile bug run <<< "$trial"
  DONE=$((DONE + 1))

  RESULT_FILE="$SCRIPT_DIR/../results/type/T1/P${profile}-bug${bug}-run${run}.json"
  if $RESUME && [[ -f "$RESULT_FILE" ]]; then
    SKIPPED=$((SKIPPED + 1))
    echo "[$DONE/$TOTAL] SKIP P${profile} ${bug} run${run}"
    continue
  fi

  echo ""
  echo "[$DONE/$TOTAL] P${profile} ${bug} run${run}"
  echo "────────────────────────────────────────"

  "$SCRIPT_DIR/run-type-experiment" \
    --profile "$profile" \
    --bug "$bug" \
    --run "$run" \
    --experiment T1 \
    $DRY_RUN

done

echo ""
echo "=== T1 Complete ==="
echo "Total: $TOTAL  Skipped: $SKIPPED  Ran: $((TOTAL - SKIPPED))"
echo ""
echo "Analyze:"
echo "  bin/analyze-type-experiments --experiment T1"
