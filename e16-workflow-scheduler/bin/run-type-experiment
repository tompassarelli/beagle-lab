#!/usr/bin/env bash
set -euo pipefail

# run-type-experiment — Run one type-surface trial.
#
# Usage: bin/run-type-experiment --profile <0-3> --bug <01-10> --run <N> [--experiment <name>] [--dry-run]
#
# The workspace uses an opaque ID so the agent cannot infer the bug
# from file paths or directory names.
#
# Output: results/type/<experiment>/<profile>-<bug>-<run>.json

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
EXPERIMENT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
GOLDEN_DIR="$EXPERIMENT_DIR/golden/beagle"
TYPE_BUGS_DIR="$EXPERIMENT_DIR/type-bugs"
VERIFY_DIR="$EXPERIMENT_DIR/verify"
BEAGLE_BIN="/home/tom/code/beagle/bin/beagle"

PROFILE=""
BUG=""
RUN=""
EXPERIMENT="T1"
DRY_RUN=false
MAX_TURNS=20
CHECK_MODE="agent"  # "agent" = errors only; "default" = errors + lint

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile) PROFILE="$2"; shift 2 ;;
    --bug)     BUG="$2"; shift 2 ;;
    --run)     RUN="$2"; shift 2 ;;
    --experiment) EXPERIMENT="$2"; shift 2 ;;
    --check-mode) CHECK_MODE="$2"; shift 2 ;;
    --dry-run) DRY_RUN=true; shift ;;
    --max-turns) MAX_TURNS="$2"; shift 2 ;;
    *) echo "Unknown arg: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$PROFILE" || -z "$BUG" || -z "$RUN" ]]; then
  echo "Usage: $(basename "$0") --profile <0-3> --bug <01-10> --run <N>" >&2
  exit 1
fi

RESULT_DIR="$EXPERIMENT_DIR/results/type/$EXPERIMENT"
RESULT_FILE="$RESULT_DIR/P${PROFILE}-bug${BUG}-run${RUN}.json"

# Opaque workspace ID — no bug name, no experiment metadata visible to agent
TRIAL_ID=$(printf '%04x%04x' $RANDOM $RANDOM)
WORKSPACE="/tmp/trial-${TRIAL_ID}"

mkdir -p "$RESULT_DIR"

echo "=== Type Experiment Trial ==="
echo "Profile: P${PROFILE}  Bug: ${BUG}  Run: ${RUN}  ID: ${TRIAL_ID}"
echo "Workspace: $WORKSPACE"
echo "Result: $RESULT_FILE"
echo ""

# ── Step 1: Set up workspace ──────────────────────────────────────────────

rm -rf "$WORKSPACE"
mkdir -p "$WORKSPACE/src"

cp "$GOLDEN_DIR/"*.bgl "$WORKSPACE/src/"

bash "$TYPE_BUGS_DIR/$BUG/apply.sh" "$WORKSPACE/src"

# ── Step 2: Type check with profile, then build ──────────────────────────

# Check GOLDEN code for baseline error count at this profile.
# P1 has false positives from missing flow-narrowing; only count NEW errors.
GOLDEN_CHECK=$("$BEAGLE_BIN" check --profile "$PROFILE" "$GOLDEN_DIR/" 2>&1) || true
GOLDEN_ERRORS=$(echo "$GOLDEN_CHECK" | grep -oP '\d+ error' | grep -oP '^\d+' || echo 0)

CHECK_OUTPUT=$("$BEAGLE_BIN" check --profile "$PROFILE" "$WORKSPACE/src/" 2>&1) || true
BUGGY_ERRORS=$(echo "$CHECK_OUTPUT" | grep -oP '\d+ error' | grep -oP '^\d+' || echo 0)
CHECKER_CAUGHT=false

NEW_ERRORS=$((BUGGY_ERRORS - GOLDEN_ERRORS))
if [[ $NEW_ERRORS -gt 0 ]]; then
  CHECKER_CAUGHT=true
  ERROR_MSG=$(echo "$CHECK_OUTPUT" | grep -v '^beagle \[lint\]' | grep -E '(error\[|not exhaustive|mismatch)' | head -3)
  echo "Checker caught bug at P${PROFILE} ($NEW_ERRORS new error(s)): $ERROR_MSG"
else
  echo "Checker: $BUGGY_ERRORS errors (baseline=$GOLDEN_ERRORS, new=0)"
fi

"$BEAGLE_BIN" build --warn --out "$WORKSPACE/clj" "$WORKSPACE/src/" >/dev/null 2>&1 || true

# ── Step 3: Run baseline oracle ──────────────────────────────────────────

BASELINE_TOTAL=0
BASELINE_PASSED=0
BASELINE_FAILED=0

if [[ -d "$WORKSPACE/clj/scheduler" ]]; then
  ORACLE_OUT=$(cd "$WORKSPACE/clj" && timeout 60 bb -cp . "$VERIFY_DIR/beagle/oracle.clj" 2>&1) || true
  BASELINE_PASSED=$(echo "$ORACLE_OUT" | grep -c '^PASS:' || true)
  BASELINE_CRASHES=$(echo "$ORACLE_OUT" | grep -c 'Assert failed' || true)
  BASELINE_FAILED=$BASELINE_CRASHES
  BASELINE_TOTAL=$((BASELINE_PASSED + BASELINE_FAILED))
  echo "Baseline: ${BASELINE_PASSED}/${BASELINE_TOTAL} passed, ${BASELINE_FAILED} failed"
else
  echo "WARNING: build produced no output"
fi

# ── Step 4: Write CLAUDE.md for the agent ────────────────────────────────
# Neutral language. No bug hints. Only difference between profiles is
# the --profile flag in the check command.

cat > "$WORKSPACE/CLAUDE.md" <<AGENTEOF
# Task

A bug has been introduced into the Beagle source files in \`src/\`.
Fix the implementation so all oracle tests pass.

## Source files
- \`src/types.bgl\` — type definitions
- \`src/graph.bgl\` — dependency graph
- \`src/matcher.bgl\` — worker matching
- \`src/scheduler.bgl\` — core scheduling algorithm
- \`src/errors.bgl\` — error types
- \`src/validator.bgl\` — schedule validation

## Commands

Type check:
\`\`\`
$BEAGLE_BIN check$(if [[ "$CHECK_MODE" == "agent" ]]; then echo " --agent"; fi) --profile $PROFILE $WORKSPACE/src/
\`\`\`

Build (compile to Clojure):
\`\`\`
$BEAGLE_BIN build --warn --out $WORKSPACE/clj $WORKSPACE/src/
\`\`\`

Run tests:
\`\`\`
cd $WORKSPACE/clj && bb -cp . $VERIFY_DIR/beagle/oracle.clj
\`\`\`

## Workflow
1. Run the type checker to see any type errors.
2. Build the code.
3. Run the oracle tests to see which tests fail.
4. Read the source and failing tests to understand the expected behavior.
5. Find and fix the bug.
6. Rebuild and re-run oracle. Repeat until all tests pass.

## Rules
- Only edit files in \`src/\`.
- Always rebuild before running the oracle.
- Do not modify the oracle.
AGENTEOF

# ── Step 5: Launch agent (or dry-run) ────────────────────────────────────

AGENT_TURNS=0
AGENT_CHECK_CALLS=0
AGENT_FIXED=false
AGENT_WRONG_FIXES=0
AGENT_DURATION=0
FINAL_PASSED=0
FINAL_FAILED=0
FINAL_TOTAL=0
FIX_QUALITY="no_run"

if [[ "$CHECKER_CAUGHT" == "true" ]]; then
  echo "Checker caught this bug — skipping agent."
  AGENT_FIXED="type_caught"
  FIX_QUALITY="type_caught"
elif $DRY_RUN; then
  echo "[DRY RUN] Workspace ready at $WORKSPACE"
else
  echo "Launching Claude Code agent..."
  AGENT_START=$(date +%s)

  # Frozen prompt: neutral, no bug hints, identical across profiles.
  # --dangerously-skip-permissions: automated run in isolated temp dir.
  # --no-session-persistence: don't clutter session storage.
  # --model sonnet: consistent model across all trials.
  # timeout: hard wall-clock cap (10 min).
  AGENT_OUTPUT=$(cd "$WORKSPACE" && timeout 600 claude --print \
    --dangerously-skip-permissions \
    --no-session-persistence \
    --model sonnet \
    -p "Read CLAUDE.md and follow the instructions. A single bug has been introduced into the source code. Find and fix it so all oracle tests pass." \
    2>&1) || true

  AGENT_END=$(date +%s)
  AGENT_DURATION=$((AGENT_END - AGENT_START))

  AGENT_CHECK_CALLS=$(echo "$AGENT_OUTPUT" | grep -c "beagle build\|beagle check" || true)

  # Save agent transcript
  echo "$AGENT_OUTPUT" > "$WORKSPACE/agent-transcript.txt"

  # Save final diff (golden → agent's edits)
  diff -ru "$GOLDEN_DIR/" "$WORKSPACE/src/" > "$WORKSPACE/final.diff" 2>/dev/null || true

  # ── Step 6: Final oracle measurement ──────────────────────────────────

  "$BEAGLE_BIN" build --warn --out "$WORKSPACE/clj" "$WORKSPACE/src/" >/dev/null 2>&1 || true

  FINAL_OUT=$(cd "$WORKSPACE/clj" && timeout 60 bb -cp . "$VERIFY_DIR/beagle/oracle.clj" 2>&1) || true
  FINAL_PASSED=$(echo "$FINAL_OUT" | grep -c '^PASS:' || true)
  FINAL_CRASHES=$(echo "$FINAL_OUT" | grep -c 'Assert failed' || true)
  FINAL_FAILED=$FINAL_CRASHES
  FINAL_TOTAL=$((FINAL_PASSED + FINAL_FAILED))

  # Determine fix quality:
  #   clean_fix   — all tests pass, no regressions
  #   fix_regress — all originally-failing tests fixed, but some originally-passing now fail
  #   partial     — some improvement but not all tests pass
  #   no_change   — same as baseline
  #   worse       — more tests fail than baseline
  if [[ "$FINAL_FAILED" -eq 0 && "$FINAL_PASSED" -gt 0 ]]; then
    AGENT_FIXED=true
    if [[ "$FINAL_PASSED" -ge "$BASELINE_TOTAL" ]]; then
      FIX_QUALITY="clean_fix"
    else
      FIX_QUALITY="fix_regress"
    fi
  elif [[ "$FINAL_PASSED" -gt "$BASELINE_PASSED" ]]; then
    FIX_QUALITY="partial"
  elif [[ "$FINAL_PASSED" -eq "$BASELINE_PASSED" && "$FINAL_FAILED" -eq "$BASELINE_FAILED" ]]; then
    FIX_QUALITY="no_change"
  elif [[ "$FINAL_PASSED" -lt "$BASELINE_PASSED" ]]; then
    FIX_QUALITY="worse"
    AGENT_WRONG_FIXES=$((BASELINE_PASSED - FINAL_PASSED))
  else
    FIX_QUALITY="no_change"
  fi

  echo "Final: ${FINAL_PASSED}/${FINAL_TOTAL} passed, ${FINAL_FAILED} failed"
  echo "Quality: ${FIX_QUALITY}  Duration: ${AGENT_DURATION}s  Checks: ${AGENT_CHECK_CALLS}"
fi

# ── Step 7: Write result JSON ────────────────────────────────────────────

FIXED_JSON=$(if [[ "$AGENT_FIXED" == "true" || "$AGENT_FIXED" == "false" ]]; then echo "$AGENT_FIXED"; else echo "\"$AGENT_FIXED\""; fi)

cat > "$RESULT_FILE" <<EOF
{
  "experiment": "$EXPERIMENT",
  "profile": $PROFILE,
  "bug": "$BUG",
  "run": $RUN,
  "trial_id": "$TRIAL_ID",
  "check_mode": "$CHECK_MODE",
  "checker_caught": $CHECKER_CAUGHT,
  "baseline": {
    "total": $BASELINE_TOTAL,
    "passed": $BASELINE_PASSED,
    "failed": $BASELINE_FAILED
  },
  "final": {
    "total": $FINAL_TOTAL,
    "passed": $FINAL_PASSED,
    "failed": $FINAL_FAILED
  },
  "agent": {
    "fixed": $FIXED_JSON,
    "fix_quality": "$FIX_QUALITY",
    "wrong_fixes": $AGENT_WRONG_FIXES,
    "check_calls": $AGENT_CHECK_CALLS,
    "turns": $AGENT_TURNS,
    "duration_s": $AGENT_DURATION
  },
  "timestamp": "$(date -Iseconds)",
  "workspace": "$WORKSPACE"
}
EOF

# Copy final diff to results if it exists
if [[ -f "$WORKSPACE/final.diff" ]]; then
  cp "$WORKSPACE/final.diff" "$RESULT_DIR/P${PROFILE}-bug${BUG}-run${RUN}.diff"
fi

echo "Result: $RESULT_FILE"
