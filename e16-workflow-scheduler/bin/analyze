#!/usr/bin/env bash
set -euo pipefail

# analyze — Read result JSONs from results/ and print summary tables.
#
# Usage: bin/analyze [results_dir]

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
EXPERIMENT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
RESULTS_DIR="${1:-$EXPERIMENT_DIR/results}"

if [[ ! -d "$RESULTS_DIR" ]]; then
  echo "Error: results directory '$RESULTS_DIR' not found" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Collect all summary files
# ---------------------------------------------------------------------------

SUMMARIES=()
while IFS= read -r -d '' f; do
  SUMMARIES+=("$f")
done < <(find "$RESULTS_DIR" -name '*-summary.json' -print0 | sort -z)

if [[ ${#SUMMARIES[@]} -eq 0 ]]; then
  echo "No summary files found in $RESULTS_DIR"
  exit 0
fi

# ---------------------------------------------------------------------------
# JSON field extractor (no jq dependency)
# ---------------------------------------------------------------------------

json_field() {
  local json="$1" field="$2"
  echo "$json" | grep -oP "\"$field\":\s*\K[^,}\s]+" | tr -d '"' || echo ""
}

json_nested() {
  local json="$1" parent="$2" field="$3"
  # Extract the nested object first, then the field
  local nested
  nested=$(echo "$json" | grep -oP "\"$parent\":\s*\{[^}]+\}" || echo "")
  echo "$nested" | grep -oP "\"$field\":\s*\K[0-9]+" || echo "0"
}

# ---------------------------------------------------------------------------
# 1. Per-trial detail table
# ---------------------------------------------------------------------------

echo "================================================================"
echo "E16 Workflow Scheduler — Experiment Results"
echo "================================================================"
echo ""

printf "%-8s  %-30s  %-4s  %-10s  %-10s  %-6s  %-5s  %-9s\n" \
  "TRACK" "BUG" "RUN" "BASELINE" "FINAL" "FIXED" "REGR" "RESTORED"
printf "%-8s  %-30s  %-4s  %-10s  %-10s  %-6s  %-5s  %-9s\n" \
  "--------" "------------------------------" "----" "----------" "----------" "------" "-----" "---------"

declare -A TRACK_FIXES TRACK_RUNS TRACK_REGRESSIONS TRACK_RESTORED
declare -A BUG_TRACKS_FIXED BUG_TRACKS_TRIED

for f in "${SUMMARIES[@]}"; do
  JSON=$(cat "$f")
  TRACK=$(json_field "$JSON" "track")
  BUG=$(json_field "$JSON" "bug_id")
  RUN=$(json_field "$JSON" "run")
  FIXED=$(json_field "$JSON" "fixed")
  REGR=$(json_field "$JSON" "regressions")
  RESTORED=$(json_field "$JSON" "assertions_restored")
  B_PASSED=$(json_nested "$JSON" "baseline" "passed")
  B_TOTAL=$(json_nested "$JSON" "baseline" "total")
  F_PASSED=$(json_nested "$JSON" "final" "passed")
  F_TOTAL=$(json_nested "$JSON" "final" "total")

  printf "%-8s  %-30s  %-4s  %3s/%-6s  %3s/%-6s  %-6s  %-5s  %-9s\n" \
    "$TRACK" "$BUG" "$RUN" "$B_PASSED" "$B_TOTAL" "$F_PASSED" "$F_TOTAL" \
    "$FIXED" "$REGR" "$RESTORED"

  # Accumulate per-track stats
  TRACK_RUNS[$TRACK]=$(( ${TRACK_RUNS[$TRACK]:-0} + 1 ))
  if [[ "$FIXED" == "true" ]]; then
    TRACK_FIXES[$TRACK]=$(( ${TRACK_FIXES[$TRACK]:-0} + 1 ))
  fi
  TRACK_REGRESSIONS[$TRACK]=$(( ${TRACK_REGRESSIONS[$TRACK]:-0} + REGR ))
  TRACK_RESTORED[$TRACK]=$(( ${TRACK_RESTORED[$TRACK]:-0} + RESTORED ))

  # Accumulate per-bug stats
  BUG_TRACKS_TRIED[$BUG]="${BUG_TRACKS_TRIED[$BUG]:-} $TRACK"
  if [[ "$FIXED" == "true" ]]; then
    BUG_TRACKS_FIXED[$BUG]="${BUG_TRACKS_FIXED[$BUG]:-} $TRACK"
  fi
done

# ---------------------------------------------------------------------------
# 2. Per-track summary
# ---------------------------------------------------------------------------

echo ""
echo "--- Per-Track Summary ---"
echo ""
printf "%-8s  %-6s  %-9s  %-14s  %-14s\n" \
  "TRACK" "RUNS" "FIX RATE" "AVG REGRESS" "AVG RESTORED"
printf "%-8s  %-6s  %-9s  %-14s  %-14s\n" \
  "--------" "------" "---------" "--------------" "--------------"

for TRACK in beagle python; do
  RUNS=${TRACK_RUNS[$TRACK]:-0}
  if [[ $RUNS -eq 0 ]]; then continue; fi
  FIXES=${TRACK_FIXES[$TRACK]:-0}
  REGR=${TRACK_REGRESSIONS[$TRACK]:-0}
  RESTORED=${TRACK_RESTORED[$TRACK]:-0}

  RATE="$FIXES/$RUNS"
  if [[ $RUNS -gt 0 ]]; then
    PCT=$(( FIXES * 100 / RUNS ))
    RATE="$FIXES/$RUNS (${PCT}%)"
  fi

  # Integer average (good enough for a summary)
  AVG_REGR=$(( REGR / RUNS ))
  AVG_REST=$(( RESTORED / RUNS ))

  printf "%-8s  %-6s  %-9s  %-14s  %-14s\n" \
    "$TRACK" "$RUNS" "$RATE" "$AVG_REGR" "$AVG_REST"
done

# ---------------------------------------------------------------------------
# 3. Per-bug summary
# ---------------------------------------------------------------------------

echo ""
echo "--- Per-Bug Summary ---"
echo ""
printf "%-30s  %-30s  %-30s\n" "BUG" "TRIED" "FIXED BY"
printf "%-30s  %-30s  %-30s\n" \
  "------------------------------" "------------------------------" "------------------------------"

# Deduplicate and sort bug IDs
BUGS=($(for b in "${!BUG_TRACKS_TRIED[@]}"; do echo "$b"; done | sort))

for BUG in "${BUGS[@]}"; do
  TRIED=$(echo "${BUG_TRACKS_TRIED[$BUG]}" | xargs -n1 | sort -u | xargs)
  FIXED=$(echo "${BUG_TRACKS_FIXED[$BUG]:-none}" | xargs -n1 | sort -u | xargs)
  if [[ -z "$FIXED" || "$FIXED" == "none" ]]; then
    FIXED="(none)"
  fi
  printf "%-30s  %-30s  %-30s\n" "$BUG" "$TRIED" "$FIXED"
done

# ---------------------------------------------------------------------------
# 4. Head-to-head comparison
# ---------------------------------------------------------------------------

echo ""
echo "--- Head-to-Head ---"
echo ""

ALL_TRACKS=(beagle python)
ACTIVE_TRACKS=()
for T in "${ALL_TRACKS[@]}"; do
  if [[ ${TRACK_RUNS[$T]:-0} -gt 0 ]]; then
    ACTIVE_TRACKS+=("$T")
  fi
done

if [[ ${#ACTIVE_TRACKS[@]} -ge 2 ]]; then
  # Print header
  printf "%-14s" ""
  for T in "${ACTIVE_TRACKS[@]}"; do
    printf "  %-10s" "$T"
  done
  echo ""

  # Fix rate row
  printf "%-14s" "Fix rate"
  for T in "${ACTIVE_TRACKS[@]}"; do
    RUNS=${TRACK_RUNS[$T]:-0}
    FIXES=${TRACK_FIXES[$T]:-0}
    if [[ $RUNS -gt 0 ]]; then
      PCT=$(( FIXES * 100 / RUNS ))
      printf "  %-10s" "${PCT}%"
    else
      printf "  %-10s" "-"
    fi
  done
  echo ""

  # Avg regressions row
  printf "%-14s" "Avg regress"
  for T in "${ACTIVE_TRACKS[@]}"; do
    RUNS=${TRACK_RUNS[$T]:-0}
    REGR=${TRACK_REGRESSIONS[$T]:-0}
    if [[ $RUNS -gt 0 ]]; then
      printf "  %-10s" "$(( REGR / RUNS ))"
    else
      printf "  %-10s" "-"
    fi
  done
  echo ""

  # Avg restored row
  printf "%-14s" "Avg restored"
  for T in "${ACTIVE_TRACKS[@]}"; do
    RUNS=${TRACK_RUNS[$T]:-0}
    RESTORED=${TRACK_RESTORED[$T]:-0}
    if [[ $RUNS -gt 0 ]]; then
      printf "  %-10s" "$(( RESTORED / RUNS ))"
    else
      printf "  %-10s" "-"
    fi
  done
  echo ""
else
  echo "(Need results from at least 2 tracks for head-to-head comparison)"
fi

echo ""
echo "Total experiments: ${#SUMMARIES[@]}"
