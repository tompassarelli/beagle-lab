#!/usr/bin/env bash
set -euo pipefail

# run-oracle — Run the verification oracle for a track against a workspace.
#
# Usage: bin/run-oracle <track> <workspace_dir> [--json]
#
# Exit code: 0 if all tests pass, 1 if any fail.
# With --json: prints a JSON summary to stdout instead of raw output.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
EXPERIMENT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
VERIFY_DIR="$EXPERIMENT_DIR/verify"

usage() {
  echo "Usage: $(basename "$0") <track> <workspace_dir> [--json]"
  echo "Tracks: beagle, python"
  exit 1
}

if [[ $# -lt 2 ]]; then
  usage
fi

TRACK="$1"
WORKSPACE="$2"
JSON_MODE=false
if [[ "${3:-}" == "--json" ]]; then
  JSON_MODE=true
fi

if [[ "$TRACK" != "beagle" && "$TRACK" != "python" ]]; then
  echo "Error: unknown track '$TRACK'" >&2
  exit 1
fi

if [[ ! -d "$WORKSPACE" ]]; then
  echo "Error: workspace '$WORKSPACE' does not exist" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Parse oracle output into total/passed/failed
# ---------------------------------------------------------------------------

parse_beagle() {
  local output="$1"
  # The oracle's run-test catches Exception but not AssertionError (Error).
  # When an assertion fails, bb crashes — the summary line only reflects
  # tests that ran before the crash.  Always count individual PASS/FAIL
  # lines for robustness.
  #
  # Note: grep -c returns exit 1 when count is 0, but still prints "0".
  # Use a subshell trick to avoid the || echo double-output problem.
  PASSED=$(echo "$output" | grep -c '^PASS:' || true)
  FAILED=$(echo "$output" | grep -c '^FAIL:' || true)

  # Detect crash: exit code non-zero but no FAIL lines means bb aborted
  # on an uncaught AssertionError.  Count assertion errors in the output.
  if [[ $EXIT_CODE -ne 0 && "$FAILED" -eq 0 ]]; then
    local crashes
    crashes=$(echo "$output" | grep -c 'Assert failed' || true)
    if [[ $crashes -gt 0 ]]; then
      # bb aborts on the first uncaught error, so at least 1 test failed.
      # We can't know exactly how many would have failed in the remaining
      # untested portion, but we know this one did.
      FAILED=$crashes
    fi
  fi

  TOTAL=$((PASSED + FAILED))
}

parse_python() {
  local output="$1"
  # pytest summary: "118 passed" or "115 passed, 3 failed"
  local summary
  summary=$(echo "$output" | grep -E '=+ .* =+$' | tail -1 || true)
  PASSED=$(echo "$summary" | grep -oP '[0-9]+ passed' | grep -oP '[0-9]+' || echo 0)
  FAILED=$(echo "$summary" | grep -oP '[0-9]+ failed' | grep -oP '[0-9]+' || echo 0)
  local errors
  errors=$(echo "$summary" | grep -oP '[0-9]+ error' | grep -oP '[0-9]+' || echo 0)
  FAILED=$((FAILED + errors))
  TOTAL=$((PASSED + FAILED))
}

# ---------------------------------------------------------------------------
# Run the oracle
# ---------------------------------------------------------------------------

TOTAL=0
PASSED=0
FAILED=0
EXIT_CODE=0

case "$TRACK" in
  beagle)
    CLJ_DIR="$WORKSPACE/_clj"
    if [[ ! -d "$CLJ_DIR" ]]; then
      # Maybe the workspace IS the clj directory already
      if [[ -d "$WORKSPACE/scheduler" ]]; then
        CLJ_DIR="$WORKSPACE"
      else
        echo "Error: no compiled clj found at $CLJ_DIR or $WORKSPACE/scheduler/" >&2
        exit 1
      fi
    fi
    OUTPUT=$(cd "$CLJ_DIR" && bb -cp . "$VERIFY_DIR/beagle/oracle.clj" 2>&1) || EXIT_CODE=$?
    parse_beagle "$OUTPUT"
    ;;

  python)
    # --noconftest: skip verify/python/conftest.py which hardcodes golden path.
    # PYTHONPATH makes the workspace's python/ package importable instead.
    OUTPUT=$(
      nix-shell -p "python3.withPackages (ps: [ ps.pytest ])" --run \
        "PYTHONPATH='$WORKSPACE' python3 -m pytest '$VERIFY_DIR/python/test_oracle.py' -v --tb=short --noconftest 2>&1"
    ) || EXIT_CODE=$?
    parse_python "$OUTPUT"
    ;;
esac

# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------

if $JSON_MODE; then
  cat <<EOF
{"total": $TOTAL, "passed": $PASSED, "failed": $FAILED, "exit_code": $EXIT_CODE}
EOF
else
  echo "$OUTPUT"
  echo ""
  echo "--- Summary: $PASSED/$TOTAL passed, $FAILED failed ---"
fi

exit "$EXIT_CODE"
