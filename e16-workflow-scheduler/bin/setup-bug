#!/usr/bin/env bash
set -euo pipefail

# setup-bug — Copy golden code into a workspace and apply a bug patch.
#
# Usage: bin/setup-bug <track> <bug_id> <workspace_dir>
#
# Tracks: beagle, python

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
EXPERIMENT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
GOLDEN_DIR="$EXPERIMENT_DIR/golden"
BUGS_DIR="$EXPERIMENT_DIR/bugs"
BEAGLE_BIN="/home/tom/code/beagle/bin/beagle"

usage() {
  echo "Usage: $(basename "$0") <track> <bug_id> <workspace_dir>"
  echo "Tracks: beagle, python"
  exit 1
}

if [[ $# -lt 3 ]]; then
  usage
fi

TRACK="$1"
BUG_ID="$2"
WORKSPACE="$3"

if [[ "$TRACK" != "beagle" && "$TRACK" != "python" ]]; then
  echo "Error: unknown track '$TRACK' (expected: beagle, python)" >&2
  exit 1
fi

# 1. Create workspace
mkdir -p "$WORKSPACE"

# 2. Copy golden code
echo "Copying golden $TRACK code to $WORKSPACE ..."
case "$TRACK" in
  beagle)
    cp "$GOLDEN_DIR/beagle/"*.bgl "$WORKSPACE/"
    ;;
  python)
    # The test oracle imports "from python import ...", so the workspace
    # must contain a python/ package directory.  Copy golden into it.
    mkdir -p "$WORKSPACE/python"
    rsync -a --exclude '__pycache__' "$GOLDEN_DIR/python/" "$WORKSPACE/python/"
    ;;
esac

# 3. For beagle: build .bgl -> .clj
if [[ "$TRACK" == "beagle" ]]; then
  echo "Building beagle -> clj ..."
  (cd "$WORKSPACE" && "$BEAGLE_BIN" build . --out "$WORKSPACE/_clj" 2>&1)
fi

# 4. Apply bug patch (if it exists for this track)
#    Patches use paths like a/golden/<track>/file.ext.
#    For python: code lives at $WORKSPACE/python/, apply from $WORKSPACE with -p2
#      (strips "a/golden/" leaving "python/file.ext")
#    For beagle: code lives at $WORKSPACE/, strip "a/golden/<track>/" with -p3
PATCH_FILE="$BUGS_DIR/$BUG_ID/${TRACK}.patch"
if [[ -f "$PATCH_FILE" ]]; then
  echo "Applying patch: $PATCH_FILE ..."
  case "$TRACK" in
    python)  (cd "$WORKSPACE" && patch -p2 < "$PATCH_FILE") ;;
    *)       (cd "$WORKSPACE" && patch -p3 < "$PATCH_FILE") ;;
  esac
else
  echo "Warning: no patch found at $PATCH_FILE (skipping)" >&2
fi

# 5. For beagle: rebuild after patching .bgl source
if [[ "$TRACK" == "beagle" ]]; then
  echo "Rebuilding beagle after patch ..."
  (cd "$WORKSPACE" && "$BEAGLE_BIN" build . --out "$WORKSPACE/_clj" 2>&1)
fi

echo "Workspace ready: $WORKSPACE"
