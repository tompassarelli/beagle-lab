#!/usr/bin/env bash
set -euo pipefail

# run-feature-experiment — Run one feature-building trial.
#
# Usage: bin/run-feature-experiment --feature <A|B> --profile <0|2> --run <N> [--experiment <name>] [--dry-run]

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
EXPERIMENT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
GOLDEN_DIR="$EXPERIMENT_DIR/golden/beagle"
FEATURE_DIR="$EXPERIMENT_DIR/feature-tasks"
BEAGLE_BIN="/home/tom/code/beagle/bin/beagle"

FEATURE=""
PROFILE=""
RUN=""
EXPERIMENT="F1"
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --feature)    FEATURE="$2"; shift 2 ;;
    --profile)    PROFILE="$2"; shift 2 ;;
    --run)        RUN="$2"; shift 2 ;;
    --experiment) EXPERIMENT="$2"; shift 2 ;;
    --dry-run)    DRY_RUN=true; shift ;;
    *) echo "Unknown arg: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$FEATURE" || -z "$PROFILE" || -z "$RUN" ]]; then
  echo "Usage: $(basename "$0") --feature <A|B> --profile <0|2> --run <N>" >&2
  exit 1
fi

# Resolve feature directory
case "$FEATURE" in
  A) FEATURE_NAME="A-task-groups" ;;
  B) FEATURE_NAME="B-resource-maintenance" ;;
  C) FEATURE_NAME="C-worker-load-limits" ;;
  D) FEATURE_NAME="D-cost-budgets" ;;
  E) FEATURE_NAME="E-exclusive-resources" ;;
  *) echo "Unknown feature: $FEATURE (use A-E)" >&2; exit 1 ;;
esac

TASK_DIR="$FEATURE_DIR/$FEATURE_NAME"
RESULT_DIR="$EXPERIMENT_DIR/results/type/$EXPERIMENT"
RESULT_FILE="$RESULT_DIR/F${FEATURE}-P${PROFILE}-run${RUN}.json"

TRIAL_ID=$(printf '%04x%04x' $RANDOM $RANDOM)
WORKSPACE="/tmp/trial-${TRIAL_ID}"

mkdir -p "$RESULT_DIR"

echo "=== Feature Experiment Trial ==="
echo "Feature: ${FEATURE} (${FEATURE_NAME})  Profile: P${PROFILE}  Run: ${RUN}  ID: ${TRIAL_ID}"
echo "Workspace: $WORKSPACE"
echo "Result: $RESULT_FILE"
echo ""

# ── Step 1: Set up workspace ──────────────────────────────────────────────

rm -rf "$WORKSPACE"
mkdir -p "$WORKSPACE/src"
mkdir -p "$WORKSPACE/tests"

# Copy golden source files (unmodified — agent builds the feature)
cp "$GOLDEN_DIR/"*.bgl "$WORKSPACE/src/"

# Copy visible oracle (agent can run this)
cp "$TASK_DIR/visible-oracle.clj" "$WORKSPACE/tests/feature-tests.clj"

# Copy feature spec
cp "$TASK_DIR/spec.md" "$WORKSPACE/feature-spec.md"

# ── Step 2: Write CLAUDE.md ──────────────────────────────────────────────

CHECK_FLAG=""
CHECK_CMD=""
CHECK_WORKFLOW=""
CHECK_RULE=""
if [[ "$PROFILE" -gt 0 ]]; then
  CHECK_FLAG=" --profile $PROFILE"
  CHECK_CMD="
Type check (errors only, fast):
\`\`\`
$BEAGLE_BIN check --agent --profile $PROFILE $WORKSPACE/src/
\`\`\`
"
  CHECK_WORKFLOW="5. Run the type checker. Fix any exhaustive-match errors (these point to match sites you missed). Iterate until 0 errors."
  CHECK_RULE="- After tests pass, run the type checker to catch missed match sites — it reports only real errors."
fi

cat > "$WORKSPACE/CLAUDE.md" <<AGENTEOF
# Task

Implement the feature described in \`feature-spec.md\`.

## Source files
- \`src/types.bgl\` — type definitions
- \`src/graph.bgl\` — dependency graph
- \`src/matcher.bgl\` — worker matching
- \`src/scheduler.bgl\` — core scheduling algorithm
- \`src/errors.bgl\` — error types and descriptions
- \`src/validator.bgl\` — schedule validation

## Commands

Build (compile to Clojure):
\`\`\`
$BEAGLE_BIN build --warn --out $WORKSPACE/clj $WORKSPACE/src/
\`\`\`

Run feature tests:
\`\`\`
cd $WORKSPACE/clj && bb -cp . $WORKSPACE/tests/feature-tests.clj
\`\`\`
${CHECK_CMD}
## Workflow
1. Read \`feature-spec.md\` to understand the feature requirements.
2. Read the existing source files to understand the codebase.
3. Implement the feature across all affected files.
4. Build and run feature tests. Iterate until all tests pass.
${CHECK_WORKFLOW}

## Rules
- Only edit files in \`src/\`.
- Do not modify test files.
- Always rebuild before running tests.
- Make sure existing behavior is preserved (the feature extends, not replaces).
${CHECK_RULE}
AGENTEOF

# ── Step 3: Type check baseline ──────────────────────────────────────────

if [[ "$PROFILE" -gt 0 ]]; then
  GOLDEN_CHECK=$("$BEAGLE_BIN" check --profile "$PROFILE" "$GOLDEN_DIR/" 2>&1) || true
  GOLDEN_ERRORS=$(echo "$GOLDEN_CHECK" | grep -oP '\d+ error' | grep -oP '^\d+' || echo 0)
  echo "Baseline type errors at P${PROFILE}: $GOLDEN_ERRORS"
else
  GOLDEN_ERRORS=0
  echo "Profile P0: no type checking"
fi

# ── Step 4: Launch agent (or dry-run) ────────────────────────────────────

AGENT_DURATION=0
VISIBLE_PASSED=0
VISIBLE_FAILED=0
VISIBLE_TOTAL=0
HIDDEN_PASSED=0
HIDDEN_FAILED=0
HIDDEN_TOTAL=0
FINAL_TYPE_ERRORS=0
FIX_QUALITY="no_run"

if $DRY_RUN; then
  echo "[DRY RUN] Workspace ready at $WORKSPACE"
else
  echo "Launching Claude Code agent..."
  AGENT_START=$(date +%s)

  AGENT_OUTPUT=$(cd "$WORKSPACE" && timeout 600 claude --print \
    --dangerously-skip-permissions \
    --no-session-persistence \
    --model sonnet \
    -p "Read CLAUDE.md and follow the instructions. Implement the feature described in feature-spec.md. Make all feature tests pass while preserving existing behavior." \
    2>&1) || true

  AGENT_END=$(date +%s)
  AGENT_DURATION=$((AGENT_END - AGENT_START))

  echo "$AGENT_OUTPUT" > "$WORKSPACE/agent-transcript.txt"
  diff -ru "$GOLDEN_DIR/" "$WORKSPACE/src/" > "$WORKSPACE/final.diff" 2>/dev/null || true

  # ── Step 5: Post-agent measurement ────────────────────────────────────

  # Build agent's code
  "$BEAGLE_BIN" build --warn --out "$WORKSPACE/clj" "$WORKSPACE/src/" >/dev/null 2>&1 || true

  # Final type check
  if [[ "$PROFILE" -gt 0 ]]; then
    FINAL_CHECK=$("$BEAGLE_BIN" check --profile "$PROFILE" "$WORKSPACE/src/" 2>&1) || true
    FINAL_TYPE_ERRORS=$(echo "$FINAL_CHECK" | grep -oP '\d+ error' | grep -oP '^\d+' || echo 0)
    echo "Final type errors: $FINAL_TYPE_ERRORS (baseline: $GOLDEN_ERRORS)"
  fi

  # Run visible oracle
  # Note: bb crashes on AssertionError, so count PASS lines and derive failures
  # from total test count in the oracle file.
  if [[ -d "$WORKSPACE/clj/scheduler" ]]; then
    VISIBLE_OUT=$(cd "$WORKSPACE/clj" && timeout 60 bb -cp . "$WORKSPACE/tests/feature-tests.clj" 2>&1) || true
    VISIBLE_PASSED=$(echo "$VISIBLE_OUT" | grep -c '^PASS:' || true)
    VISIBLE_TOTAL=$(grep -c '(run-test "' "$WORKSPACE/tests/feature-tests.clj" || true)
    VISIBLE_FAILED=$((VISIBLE_TOTAL - VISIBLE_PASSED))
    echo "Visible oracle: ${VISIBLE_PASSED}/${VISIBLE_TOTAL} passed, ${VISIBLE_FAILED} failed"

    # Run hidden oracle
    HIDDEN_OUT=$(cd "$WORKSPACE/clj" && timeout 60 bb -cp . "$TASK_DIR/hidden-oracle.clj" 2>&1) || true
    HIDDEN_PASSED=$(echo "$HIDDEN_OUT" | grep -c '^PASS:' || true)
    HIDDEN_TOTAL=$(grep -c '(run-test "' "$TASK_DIR/hidden-oracle.clj" || true)
    HIDDEN_FAILED=$((HIDDEN_TOTAL - HIDDEN_PASSED))
    echo "Hidden oracle:  ${HIDDEN_PASSED}/${HIDDEN_TOTAL} passed, ${HIDDEN_FAILED} failed"
  else
    echo "WARNING: build produced no output"
  fi

  # ── Step 6: Score quality ─────────────────────────────────────────────

  if [[ "$VISIBLE_TOTAL" -eq 0 ]]; then
    FIX_QUALITY="broken_build"
  elif [[ "$VISIBLE_FAILED" -gt 0 ]]; then
    FIX_QUALITY="visible_incomplete"
  elif [[ "$HIDDEN_FAILED" -eq 0 && "$HIDDEN_TOTAL" -gt 0 ]]; then
    FIX_QUALITY="complete"
  elif [[ "$HIDDEN_FAILED" -gt 0 ]]; then
    FIX_QUALITY="partial"
  else
    FIX_QUALITY="unknown"
  fi

  echo "Quality: ${FIX_QUALITY}  Duration: ${AGENT_DURATION}s"
fi

# ── Step 7: Write result JSON ────────────────────────────────────────────

cat > "$RESULT_FILE" <<EOF
{
  "experiment": "$EXPERIMENT",
  "feature": "$FEATURE",
  "feature_name": "$FEATURE_NAME",
  "profile": $PROFILE,
  "run": $RUN,
  "trial_id": "$TRIAL_ID",
  "visible_oracle": {
    "total": $VISIBLE_TOTAL,
    "passed": $VISIBLE_PASSED,
    "failed": $VISIBLE_FAILED
  },
  "hidden_oracle": {
    "total": $HIDDEN_TOTAL,
    "passed": $HIDDEN_PASSED,
    "failed": $HIDDEN_FAILED
  },
  "final_type_errors": $FINAL_TYPE_ERRORS,
  "baseline_type_errors": $GOLDEN_ERRORS,
  "fix_quality": "$FIX_QUALITY",
  "duration_s": $AGENT_DURATION,
  "timestamp": "$(date -Iseconds)",
  "workspace": "$WORKSPACE"
}
EOF

if [[ -f "$WORKSPACE/final.diff" ]]; then
  cp "$WORKSPACE/final.diff" "$RESULT_DIR/F${FEATURE}-P${PROFILE}-run${RUN}.diff"
fi

echo "Result: $RESULT_FILE"
