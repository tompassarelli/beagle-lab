#!/usr/bin/env bash
set -euo pipefail

# run-F3-instrumented — Re-run features A and E (2 reps) with checker
# invocation logging. Confirms the exhaustive-match mechanism fires for P2.
#
# Uses the same F3-corrected experiment name so results land alongside
# the original run1 data. Runs 2-3 are new.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

DRY_RUN=""
[[ "${1:-}" == "--dry-run" ]] && DRY_RUN="--dry-run"

FEATURES=(A E)
PROFILES=(0 2)
RUNS=(2 3)

TRIALS=()
for run in "${RUNS[@]}"; do
  for profile in "${PROFILES[@]}"; do
    for feature in "${FEATURES[@]}"; do
      TRIALS+=("$feature|$profile|$run")
    done
  done
done

SHUFFLED=($(printf '%s\n' "${TRIALS[@]}" | shuf))

TOTAL=${#SHUFFLED[@]}
DONE=0

echo "=== F3-instrumented: A+E reps with checker logging ==="
echo "Features: ${FEATURES[*]}  Profiles: ${PROFILES[*]}  Runs: ${RUNS[*]}  Total: $TOTAL"
echo "Order: randomized"
echo ""

for trial in "${SHUFFLED[@]}"; do
  IFS='|' read -r feature profile run <<< "$trial"
  DONE=$((DONE + 1))

  echo ""
  echo "[$DONE/$TOTAL] Feature ${feature} P${profile} run${run}"
  echo "────────────────────────────────────────"

  "$SCRIPT_DIR/run-feature-experiment" \
    --feature "$feature" \
    --profile "$profile" \
    --run "$run" \
    --experiment F3-corrected \
    $DRY_RUN

done

echo ""
echo "=== F3-instrumented Complete ==="
echo "Total: $TOTAL  Ran: $TOTAL"
