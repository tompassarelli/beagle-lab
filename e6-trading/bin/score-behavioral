#!/usr/bin/env bash
set -euo pipefail

# Usage: score-behavioral <trial-dir>
# Runs the behavioral verify script and reports pass/fail count

TRIAL_DIR="${1:?Usage: score-behavioral <trial-dir>}"

if [ ! -d "$TRIAL_DIR" ]; then
  echo "ERROR: $TRIAL_DIR does not exist"
  exit 1
fi

VERIFY="$TRIAL_DIR/behavioral.verify.clj"
if [ ! -f "$VERIFY" ]; then
  echo "ERROR: No behavioral.verify.clj in $TRIAL_DIR"
  exit 1
fi

# Determine track from file extensions
if ls "$TRIAL_DIR"/*.rkt >/dev/null 2>&1; then
  TRACK="beagle"
  # Build beagle to clojure first
  SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
  BUILD_DIR="$TRIAL_DIR/.build/trading"
  mkdir -p "$BUILD_DIR"
  "$SCRIPT_DIR/../../bin/beagle-build-all" "$TRIAL_DIR"/*.rkt --out "$BUILD_DIR" 2>/dev/null || true
  CLJ_DIR="$TRIAL_DIR/.build"
elif ls "$TRIAL_DIR"/*.clj >/dev/null 2>&1; then
  TRACK="clojure"
  # Set up namespace directory structure
  CLJ_DIR="$TRIAL_DIR/.clj-run"
  mkdir -p "$CLJ_DIR/trading"
  cp "$TRIAL_DIR"/*.clj "$CLJ_DIR/trading/"
else
  echo "ERROR: No .rkt or .clj files in $TRIAL_DIR"
  exit 1
fi

echo "=== Scoring: $TRIAL_DIR ==="
echo "Track: $TRACK"
echo ""

# Run the verify script with the clojure files on classpath
cd "$CLJ_DIR"
clj -Sdeps '{:paths ["."]}' -M -e "(load-file \"$VERIFY\")" 2>&1 | tee "$TRIAL_DIR/score.txt"

echo ""
echo "Score saved to: $TRIAL_DIR/score.txt"
