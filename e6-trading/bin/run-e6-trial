#!/usr/bin/env bash
set -euo pipefail

# Usage: run-e6-trial <track> <run-number>
# track: beagle | clojure
# Example: run-e6-trial beagle 1

TRACK="${1:?Usage: run-e6-trial <beagle|clojure> <run-number>}"
RUN="${2:?Usage: run-e6-trial <beagle|clojure> <run-number>}"

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
TRIAL_DIR="$SCRIPT_DIR/trials/e6-${TRACK}-run${RUN}"

if [ -d "$TRIAL_DIR" ]; then
  echo "ERROR: $TRIAL_DIR already exists"
  exit 1
fi

mkdir -p "$TRIAL_DIR"

# Copy buggy code to trial working directory
if [ "$TRACK" = "beagle" ]; then
  cp "$SCRIPT_DIR/buggy/beagle/"*.rkt "$TRIAL_DIR/"
  EXT="rkt"
elif [ "$TRACK" = "clojure" ]; then
  cp "$SCRIPT_DIR/buggy/clojure/"*.clj "$TRIAL_DIR/"
  EXT="clj"
else
  echo "ERROR: track must be 'beagle' or 'clojure'"
  exit 1
fi

# Copy verify script
cp "$SCRIPT_DIR/verify/behavioral.verify.clj" "$TRIAL_DIR/"

# For beagle: pre-compute checker report
if [ "$TRACK" = "beagle" ]; then
  CHECKER_REPORT=$(cd "$TRIAL_DIR" && "$SCRIPT_DIR/../../bin/beagle-check-all" *.rkt 2>&1 || true)

  # Build the prompt with checker report injected
  PROMPT=$(python3 -c "
import sys
template = open('$SCRIPT_DIR/prompts/beagle-agent.md').read()
report = sys.stdin.read()
print(template.replace('{{CHECKER_REPORT}}', report))
" <<< "$CHECKER_REPORT")
else
  PROMPT=$(cat "$SCRIPT_DIR/prompts/clojure-agent.md")
fi

# Save the prompt for reference
echo "$PROMPT" > "$TRIAL_DIR/prompt.md"

echo "=== E6 Trial: $TRACK run $RUN ==="
echo "Working dir: $TRIAL_DIR"
echo "Track: $TRACK"
echo ""

if [ "$TRACK" = "beagle" ]; then
  echo "Checker report pre-computed. Errors found:"
  echo "$CHECKER_REPORT" | grep -c "error:" || echo "0"
  echo ""
fi

echo "Ready to run. Launch the agent with:"
echo "  claude --print-cost -p \"\$(cat $TRIAL_DIR/prompt.md)\" --allowedTools 'Read,Edit,Bash' --cwd $TRIAL_DIR"
