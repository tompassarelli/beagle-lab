#!/usr/bin/env bash
set -euo pipefail

# Usage: run-e6b-trial <track> <run-number>
# E6b: stripped oracle (no BUG-NN labels), improved beagle prompt with cheatsheet
# track: beagle | clojure
# Example: run-e6b-trial beagle 1

TRACK="${1:?Usage: run-e6b-trial <beagle|clojure> <run-number>}"
RUN="${2:?Usage: run-e6b-trial <beagle|clojure> <run-number>}"

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
TRIAL_DIR="$SCRIPT_DIR/trials/e6b-${TRACK}-run${RUN}"

if [ ! -d "$TRIAL_DIR" ]; then
  echo "ERROR: $TRIAL_DIR does not exist. Create it first with buggy code + prompt."
  exit 1
fi

echo "=== E6b Trial: $TRACK run $RUN ==="
echo "Working dir: $TRIAL_DIR"
echo "Track: $TRACK"
echo ""
echo "Launch the agent with:"
echo "  claude --print-cost -p \"\$(cat $TRIAL_DIR/prompt.md)\" --allowedTools 'Read,Edit,Bash' --cwd $TRIAL_DIR"
echo ""
echo "After the agent finishes, score with:"
echo "  $SCRIPT_DIR/bin/score-behavioral $TRIAL_DIR"
