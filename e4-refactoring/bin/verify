#!/usr/bin/env bash
# Verify refactored responses against the updated test suite.
set -euo pipefail

beagle_root="$(cd "$(dirname "$0")/../../.." && pwd)"
refactor_dir="$beagle_root/experiments/refactoring-test"
target_clj="$beagle_root/runtime/src/beagle/target.clj"
runtime_dir="$beagle_root/runtime"
verify_file="$refactor_dir/verify/07-project-tracker-refactored.verify.clj"

pass=0
fail=0
total=0

verify_one() {
    local response="$1"
    local ext="${response##*.}"
    local label="$(basename "$response")"

    mkdir -p "$(dirname "$target_clj")"
    total=$((total + 1))
    start_ns=$(date +%s%N)

    if [[ "$ext" == "rkt" ]]; then
        if ! racket "$response" 2>/dev/null | \
           sed -E '1,/^\(ns /s/^\(ns [a-zA-Z0-9._-]+/(ns beagle.target/' > "$target_clj"; then
            end_ns=$(date +%s%N)
            elapsed_ms=$(( (end_ns - start_ns) / 1000000 ))
            echo "$label: COMPILE_FAIL ${elapsed_ms}ms"
            fail=$((fail + 1))
            rm -f "$target_clj"
            return
        fi
    elif [[ "$ext" == "clj" ]]; then
        sed -E '1,/^\(ns /s/^\(ns [a-zA-Z0-9._-]+/(ns beagle.target/' \
            "$response" > "$target_clj"
    fi

    verify_code="$(cat "$verify_file")"
    if (cd "$runtime_dir" && \
        clojure -M -e "(require '[beagle.target :as r]) $verify_code") > /dev/null 2>&1; then
        end_ns=$(date +%s%N)
        elapsed_ms=$(( (end_ns - start_ns) / 1000000 ))
        echo "$label: PASS ${elapsed_ms}ms"
        pass=$((pass + 1))
    else
        end_ns=$(date +%s%N)
        elapsed_ms=$(( (end_ns - start_ns) / 1000000 ))
        echo "$label: BEHAVIOR_FAIL ${elapsed_ms}ms"
        fail=$((fail + 1))
    fi

    rm -f "$target_clj"
}

for response in "$refactor_dir"/responses/*; do
    [[ -f "$response" ]] || continue
    verify_one "$response"
done

echo ""
echo "=== REFACTORING TEST: $pass/$total passed, $fail failed ==="
