#!/usr/bin/env bash
# Run the Python verification script against a set of .py modules.
#
# Usage: bin/verify-python <src-dir> [verify-script]
#
# src-dir: directory containing catalog.py, customers.py, ... (13 modules)
# verify-script: defaults to verify/e8-full.verify.py
#
# Exit code: 0 if all assertions pass, 1 otherwise.

set -euo pipefail

if [[ $# -lt 1 ]]; then
    echo "usage: bin/verify-python <src-dir> [verify-script]" >&2
    exit 2
fi

src_dir="$(cd "$1" && pwd)"
exp_root="$(cd "$(dirname "$0")/.." && pwd)"
verify_script="${2:-${exp_root}/verify/e8-full.verify.py}"

if [[ ! -f "$verify_script" ]]; then
    echo "ERROR: verify script not found: $verify_script" >&2
    exit 2
fi

for mod in catalog customers inventory orders reports shipping billing procurement promotions employees analytics audit notifications; do
    if [[ ! -f "${src_dir}/${mod}.py" ]]; then
        echo "MISSING: ${src_dir}/${mod}.py" >&2
        exit 2
    fi
done

cd "$src_dir"
exec python3 "$verify_script"
