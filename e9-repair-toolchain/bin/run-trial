#!/usr/bin/env bash
# Run a single E9 trial.
#
# Usage:
#   run-trial beagle 1    # E9-beagle-run1
#   run-trial clojure 1   # E9-clojure-run1

set -euo pipefail

TRACK="${1:-beagle}"
RUN="${2:-1}"
TRIAL_DIR="$(cd "$(dirname "$0")/.." && pwd)/trials/e9-${TRACK}-run${RUN}"

if [[ -d "$TRIAL_DIR" ]]; then
    echo "Trial already exists: $TRIAL_DIR" >&2
    echo "Delete it first if you want to re-run." >&2
    exit 1
fi

mkdir -p "$TRIAL_DIR"

EXPERIMENT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
E8_DIR="$(cd "$EXPERIMENT_DIR/../e8-scaled" && pwd)"
BEAGLE_BIN="$(cd "$EXPERIMENT_DIR/../../bin" && pwd)"

# Copy buggy source
if [[ "$TRACK" == "beagle" ]]; then
    cp "$E8_DIR/buggy/beagle/"*.rkt "$TRIAL_DIR/"
    PROMPT="$EXPERIMENT_DIR/spec/e9-beagle.md"
else
    cp "$E8_DIR/buggy/clojure/"*.clj "$TRIAL_DIR/"
    PROMPT="$EXPERIMENT_DIR/spec/e9-clojure.md"
fi

# Copy prompt
cp "$PROMPT" "$TRIAL_DIR/prompt.md"

echo "=== E9 ${TRACK} run${RUN} ===" >&2
echo "  Dir: $TRIAL_DIR" >&2
echo "  Track: $TRACK" >&2
echo "" >&2

# Run claude with the prompt
cd "$TRIAL_DIR"
START_TIME=$(date +%s)

claude -p "$(cat prompt.md)" \
    --output-format json \
    --dangerously-skip-permissions \
    > output.json 2> stderr.log

END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

echo "" >&2
echo "=== Done in ${DURATION}s ===" >&2
echo "$DURATION" > duration.txt

# Extract metrics from output
if [[ -f output.json ]]; then
    python3 -c "
import json, sys
try:
    data = json.load(open('output.json'))
    if isinstance(data, dict):
        usage = data.get('usage', {})
        print(f'input_tokens: {usage.get(\"input_tokens\", \"?\")}'  )
        print(f'output_tokens: {usage.get(\"output_tokens\", \"?\")}')
    elif isinstance(data, list):
        total_in = sum(m.get('usage', {}).get('input_tokens', 0) for m in data if isinstance(m, dict))
        total_out = sum(m.get('usage', {}).get('output_tokens', 0) for m in data if isinstance(m, dict))
        print(f'input_tokens: {total_in}')
        print(f'output_tokens: {total_out}')
        print(f'turns: {len(data)}')
except Exception as e:
    print(f'metrics error: {e}', file=sys.stderr)
" > metrics.txt 2>&1 || true
fi

echo "Trial complete. Verify result:" >&2
if [[ "$TRACK" == "beagle" ]]; then
    "$BEAGLE_BIN/beagle-build-all" --warn *.rkt --out .build/ 2>/dev/null
    RESULT=$(bb -cp .build -e "(load-file \"$E8_DIR/verify/e8-full.verify.clj\")" 2>&1 | tail -1)
else
    RESULT=$(bb -cp . -e "(load-file \"$E8_DIR/verify/e8-full.verify.clj\")" 2>&1 | tail -1)
fi
echo "  $RESULT" >&2
echo "$RESULT" > verify-result.txt
